closeDropdowns = function(skip)
    for _, entry in ipairs(dropdowns) do
        if entry ~= skip then
            entry.Open = false
            if entry.Arrow then
                tween(entry.Arrow, { Rotation = 0 }, 0.12, Enum.EasingStyle.Quad)
            end
            if entry.Stroke then
                tween(entry.Stroke, { Color = Color3.fromRGB(124, 114, 136), Transparency = 0.56 }, 0.12, Enum.EasingStyle.Quad)
            end
        end
    end
    if dropdownPopup and (skip == nil or skip == false) then
        hideDropdownPopup()
    end
end

