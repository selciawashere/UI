local function makeKeybind(parent, y, titleText, descText, keyCode, mode, callback)
    local row = create("Frame", { Position = UDim2.fromOffset(0, y), Size = UDim2.new(1, 0, 0, 72), BackgroundTransparency = 1, ZIndex = 7, Parent = parent })
