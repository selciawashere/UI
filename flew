local function getMainLauncherTarget()
    local scale = uiScale and uiScale.Scale ~= 0 and uiScale.Scale or 1
    local launcherCenter = launcher.AbsolutePosition + (launcher.AbsoluteSize / 2)
    local canvasTopLeft = canvas.AbsolutePosition
    return UDim2.fromOffset(
        (launcherCenter.X - canvasTopLeft.X) / scale,
        (launcherCenter.Y - canvasTopLeft.Y) / scale
    )
end

setInterfaceVisible = function(visible)
    local nextVisible = visible == true
    local centerPosition = UDim2.fromOffset(BASE.X * 0.5, BASE.Y * 0.5)
    state.visible = nextVisible
    if not state.visible then
        if closeDropdowns then
            closeDropdowns()
        end
        if setPickerOpen then
            setPickerOpen(false)
        end
        if closeToggleMenu then
            closeToggleMenu(true)
        end
        stopKeyCapture()
        bindingKeyRef = nil
    end
    tween(launcherToggleWrap, { BackgroundColor3 = state.visible and Color3.fromRGB(33, 29, 40) or Color3.fromRGB(23, 21, 28) }, 0.18, Enum.EasingStyle.Quart)
    tween(launcherToggleStroke, { Color = state.visible and Color3.fromRGB(143, 133, 158) or Color3.fromRGB(105, 96, 117), Transparency = state.visible and 0.14 or 0.46 }, 0.18, Enum.EasingStyle.Quart)
    tween(launcherToggleIcon, { Rotation = state.visible and 90 or 270, TextColor3 = state.visible and theme.white or Color3.fromRGB(241, 238, 247) }, 0.18, Enum.EasingStyle.Quart)
    launcherSub.Text = state.visible and "Hide Menu" or "Open Menu"
    if nextVisible then
        main.Visible = true
        main.Position = getMainLauncherTarget()
        mainScale.Scale = 0.18
        tween(main, { Position = centerPosition }, 0.36, Enum.EasingStyle.Circular)
        tween(mainScale, { Scale = 1 }, 0.36, Enum.EasingStyle.Quart)
    else
        tween(main, { Position = getMainLauncherTarget() }, 0.26, Enum.EasingStyle.Circular, Enum.EasingDirection.In)
        tween(mainScale, { Scale = 0.18 }, 0.26, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        task.delay(0.26, function()
            if not state.visible and main then
                main.Visible = false
                main.Position = centerPosition
                mainScale.Scale = 1
            end
        end)
    end
end

