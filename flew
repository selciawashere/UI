    end
end))

local function createGroupBuilder(parentFrame, startY)
    local builder = {
        Parent = parentFrame,
        Cursor = startY or 12,
        Elements = {},
    }
    function builder:_fit(extra)
        local targetHeight = self.Cursor + (extra or 12)
        if self.Parent and self.Parent:IsA("Frame") and self.Parent.Size.Y.Offset < targetHeight then
            self.Parent.Size = UDim2.fromOffset(self.Parent.Size.X.Offset, targetHeight)
        end
    end
    function builder:_push(ref)
        self.Elements[#self.Elements + 1] = ref
        return ref
    end
    function builder:AddToggle(config)
        config = config or {}
        local ref = makeToggle(self.Parent, self.Cursor, config.Name or "Toggle", config.Description or "", config.Default == true, config.Keybind == true or config.Dots == true, config.Callback)
        self.Cursor = self.Cursor + 72
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddKeybindToggle(config)
        config = config or {}
        config.Dots = true
        return self:AddToggle(config)
    end
    function builder:AddSlider(config)
        config = config or {}
        local ref = makeSlider(self.Parent, self.Cursor, config.Name or "Slider", config.Description or "", config.Min or 0, config.Max or 100, config.Default or config.Value or 0, config.Format, config.Callback)
        self.Cursor = self.Cursor + 76
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddDropdown(config)
        config = config or {}
        local ref = makeDropdown(self.Parent, self.Cursor, config.Name or "Dropdown", config.Description or "", config.Width or 156, config.Options or { "Option 1" }, config.Default or config.Value or ((config.Options or {})[1] or "Option 1"), config.Callback)
        self.Cursor = self.Cursor + 84
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddMultiDropdown(config)
        config = config or {}
        local ref = makeMultiDropdown(self.Parent, self.Cursor, config.Name or "Multi Dropdown", config.Description or "", config.Width or 164, config.Options or { "Option 1" }, config.Default or {}, config.Callback)
        self.Cursor = self.Cursor + 84
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddButton(config)
        config = config or {}
        local ref = makeButton(self.Parent, self.Cursor, config.Name or "Button", config.Description or "", config.ButtonText or config.Text or "RUN", config.Callback)
        self.Cursor = self.Cursor + 72
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddKeybind(config)
        config = config or {}
        local ref = makeKeybind(self.Parent, self.Cursor, config.Name or "Keybind", config.Description or "", config.Default or config.Keybind, config.Mode, config.Callback)
        self.Cursor = self.Cursor + 72
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddTextInput(config)
        config = config or {}
        local ref = makeTextInput(self.Parent, self.Cursor, config.Name or "Text Input", config.Description or "", config.Placeholder or "Enter text", config.Default or config.Value or "", config.Callback)
        self.Cursor = self.Cursor + 84
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddTextbox(config)
        return self:AddTextInput(config)
    end
    function builder:AddTextBox(config)
        return self:AddTextInput(config)
    end
    function builder:AddColorPicker(config)
        config = config or {}
        local ref = makeColorPicker(self.Parent, self.Cursor, config.Name or "Color Picker", config.Description or "", config.Default or config.Value or state.accent, config.Callback)
        self.Cursor = self.Cursor + 72
        self:_fit(12)
        return self:_push(ref)
    end
    function builder:AddDivider(spacing)
        divider(self.Parent, self.Cursor)
        self.Cursor = self.Cursor + (spacing or 16)
        self:_fit(12)
    end
    function builder:AddLabel(config)
        local ref = makeLabel(self.Parent, self.Cursor, (type(config) == "table" and config.Text) or config or "Label")
        self.Cursor = self.Cursor + 24
        self:_fit(12)
        return self:_push(ref)
    end
    return builder
end

