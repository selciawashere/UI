local function keybindDisplay(keyCode, compact)
    if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode or keyCode == Enum.KeyCode.Unknown then
        return compact and "NONE" or "None"
    end
    return keyCode.Name:upper()
end

local function normalizeCapturedKey(keyCode)
    if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode then
        return nil
    end
    if keyCode == Enum.KeyCode.Escape or keyCode == Enum.KeyCode.Backspace or keyCode == Enum.KeyCode.Delete or keyCode == Enum.KeyCode.Unknown then
        return nil
    end
    return keyCode
end

local function keyCodesMatch(a, b)
    return typeof(a) == "EnumItem"
        and typeof(b) == "EnumItem"
        and a.EnumType == Enum.KeyCode
        and b.EnumType == Enum.KeyCode
        and a.Name == b.Name
end

local function hasBoundKey(keyCode)
    for _, ref in ipairs(bindableToggles) do
        if keyCodesMatch(ref.Keybind, keyCode) then
            return true
        end
    end
    for _, ref in ipairs(bindableKeys) do
        if keyCodesMatch(ref.Keybind, keyCode) then
            return true
        end
    end
    return false
end

local function clearDuplicateKeybind(owner, keyCode)
    if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode or keyCode == Enum.KeyCode.Unknown then
        return
    end
    for _, ref in ipairs(bindableToggles) do
        if ref ~= owner and keyCodesMatch(ref.Keybind, keyCode) then
            ref:SetKeybind(nil)
        end
    end
    for _, ref in ipairs(bindableKeys) do
        if ref ~= owner and keyCodesMatch(ref.Keybind, keyCode) then
            ref:SetKeybind(nil)
        end
    end
end

local function stopBindCapture()
    if bindingToggleRef then
        bindingToggleRef.IsListeningBind = false
    end
    if bindCaptureConnection then
        bindCaptureConnection:Disconnect()
        bindCaptureConnection = nil
    end
end

local stopKeyCapture

local function beginBindCapture(ref)
    if bindingKeyRef and bindingKeyRef.Button then
        bindingKeyRef.Button.Text = keybindDisplay(bindingKeyRef.Keybind, false)
    end
    stopKeyCapture()
    bindingKeyRef = nil
    stopBindCapture()
    bindingToggleRef = ref
    if ref then
        ref.IsListeningBind = true
        bindCaptureConnection = UserInputService.InputBegan:Connect(function(input)
            if not bindingToggleRef or bindingToggleRef ~= ref then
                return
            end
            if input.UserInputType ~= Enum.UserInputType.Keyboard then
                return
            end
            if input.KeyCode == Enum.KeyCode.Unknown then
                return
            end
            local captured = normalizeCapturedKey(input.KeyCode)
            stopBindCapture()
            bindingToggleRef = nil
            ref:SetKeybind(captured)
            refreshToggleMenu()
        end)
    end
    refreshToggleMenu()
end

stopKeyCapture = function()
    if bindingKeyRef then
        bindingKeyRef.IsListening = false
    end
    if keyCaptureConnection then
        keyCaptureConnection:Disconnect()
        keyCaptureConnection = nil
    end
end

local function beginKeyCapture(ref)
    bindingToggleRef = nil
    stopBindCapture()
    refreshToggleMenu()
    if bindingKeyRef and bindingKeyRef.Button then
        bindingKeyRef.Button.Text = keybindDisplay(bindingKeyRef.Keybind, false)
    end
    stopKeyCapture()
    bindingKeyRef = ref
    if ref and ref.Button then
        ref.Button.Text = "PRESS"
    end
    if ref then
        ref.IsListening = true
        keyCaptureConnection = UserInputService.InputBegan:Connect(function(input)
            if not bindingKeyRef or bindingKeyRef ~= ref then
                return
            end
            if input.UserInputType ~= Enum.UserInputType.Keyboard then
                return
            end
            if input.KeyCode == Enum.KeyCode.Unknown then
                return
            end
            local captured = normalizeCapturedKey(input.KeyCode)
            stopKeyCapture()
            bindingKeyRef = nil
            ref:SetKeybind(captured)
        end)
    end
end

