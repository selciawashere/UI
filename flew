local function makeTab(name, iconKind, x, w)
    local frame = create("Frame", { Position = UDim2.fromOffset(x, 5), Size = UDim2.fromOffset(w, 50), BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 9, Parent = chipBar })
    local hoverBg = create("Frame", { Size = UDim2.fromScale(1, 1), BackgroundColor3 = theme.panel2, BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 9, Parent = frame })
    corner(hoverBg, 22)
    local icon = makeAssetIcon(frame, ICON_SPRITES[iconKind] or ICON_SPRITES.target, UDim2.fromOffset(16, 16), 18, 10)
    local text = create("TextLabel", { Position = UDim2.fromOffset(46, 0), Size = UDim2.new(1, -54, 1, 0), BackgroundTransparency = 1, Font = Enum.Font.GothamSemibold, Text = name, TextColor3 = theme.muted, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 10, Parent = frame })
    local button = create("TextButton", { Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "", AutoButtonColor = false, ZIndex = 11, Parent = frame })
    local hovered = false
    local function syncVisuals(instant)
        local on = state.tab == name
        local textColor = on and theme.white or (hovered and theme.white or theme.muted)
        local iconColor = on and theme.white or (hovered and theme.white or theme.muted)
        local hoverTransparency = on and 1 or (hovered and 0.18 or 1)
        if instant then
            text.TextColor3 = textColor
            hoverBg.BackgroundTransparency = hoverTransparency
            setIconColor(icon, iconColor)
        else
            tween(text, { TextColor3 = textColor }, 0.16)
            tween(hoverBg, { BackgroundTransparency = hoverTransparency }, 0.16)
            setIconColor(icon, iconColor)
        end
    end
    button.MouseEnter:Connect(function()
        hovered = true
        syncVisuals(false)
    end)
    button.MouseLeave:Connect(function()
        hovered = false
        syncVisuals(false)
    end)
    button.MouseButton1Click:Connect(function()
        switchTab(name, x, w)
    end)
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            switchTab(name, x, w)
        end
    end)
    tabRefs[name] = { Frame = frame, Icon = icon, Text = text, Button = button, HoverBg = hoverBg, X = x, W = w, Sync = syncVisuals }
    syncVisuals(true)
end

