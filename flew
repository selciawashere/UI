local function shouldBlockBoundKeyInput()
    local focused = UserInputService:GetFocusedTextBox()
    if not focused then
        return false
    end
    if screenGui and focused:IsDescendantOf(screenGui) then
        return true
    end
    return false
end

local lastKeyTriggerTimes = {}

local function canProcessKeyPress(keyCode)
    local now = os.clock()
    local keyName = keyCode.Name
    local previous = lastKeyTriggerTimes[keyName]
    if previous and (now - previous) < 0.05 then
        return false
    end
    lastKeyTriggerTimes[keyName] = now
    return true
end

triggerBoundKeyPress = function(keyCode)
    if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode or keyCode == Enum.KeyCode.Unknown then
        return false
    end
    if not canProcessKeyPress(keyCode) then
        return false
    end
    for _, ref in ipairs(bindableToggles) do
        if keyCodesMatch(ref.Keybind, keyCode) then
            if ref.Mode == "Hold" then
                ref.Holding = true
                ref:Set(true)
            else
                ref:Set(not ref.Value)
            end
            return true
        end
    end
    for _, ref in ipairs(bindableKeys) do
        if keyCodesMatch(ref.Keybind, keyCode) then
            ref:Trigger(true)
            return true
        end
    end
    return false
end

triggerBoundKeyRelease = function(keyCode)
    if typeof(keyCode) ~= "EnumItem" or keyCode.EnumType ~= Enum.KeyCode or keyCode == Enum.KeyCode.Unknown then
        return false
    end
    local handled = false
    for _, ref in ipairs(bindableToggles) do
        if ref.Mode == "Hold" and ref.Holding and keyCodesMatch(ref.Keybind, keyCode) then
            ref.Holding = false
            ref:Set(false)
            handled = true
        end
    end
    for _, ref in ipairs(bindableKeys) do
        if ref.Mode == "Hold" and ref.Holding and keyCodesMatch(ref.Keybind, keyCode) then
            ref:Trigger(false)
            handled = true
        end
    end
    return handled
end

local function bindKeyRouterAction()
    local keycodes = {}
    for _, keyCode in ipairs(Enum.KeyCode:GetEnumItems()) do
        if keyCode ~= Enum.KeyCode.Unknown then
            keycodes[#keycodes + 1] = keyCode
        end
    end
    local function routerHandler(_, inputState, inputObject)
        local keyCode = inputObject and inputObject.KeyCode
        if typeof(keyCode) == "EnumItem" and keyCode.EnumType == Enum.KeyCode and keyCode ~= Enum.KeyCode.Unknown then
            if inputState == Enum.UserInputState.Begin then
                triggerBoundKeyPress(keyCode)
            elseif inputState == Enum.UserInputState.End or inputState == Enum.UserInputState.Cancel then
                triggerBoundKeyRelease(keyCode)
            end
        end
        return Enum.ContextActionResult.Pass
    end
    local bound = pcall(function()
        ContextActionService:BindActionAtPriority(KEYBIND_ACTION_NAME, routerHandler, false, 3000, unpack(keycodes))
    end)
    if not bound then
        pcall(function()
            ContextActionService:BindAction(KEYBIND_ACTION_NAME, routerHandler, false, unpack(keycodes))
        end)
    end
end

bindKeyRouterAction()

