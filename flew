    corner(fillGloss, 7)

    local knobShadow = create("Frame", {
        Position = UDim2.fromOffset(-2, -6),
        Size = UDim2.fromOffset(14, 32),
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = 12,
        Parent = track,
    })
    corner(knobShadow, 5)
    local knob = create("Frame", { Position = UDim2.fromOffset(0, -4), Size = UDim2.fromOffset(10, 28), BackgroundColor3 = Color3.fromRGB(247, 247, 247), BorderSizePixel = 0, ZIndex = 13, Parent = track })
    corner(knob, 4)
    stroke(knob, Color3.fromRGB(198, 197, 201), 0.34, 1)
    local knobGloss = create("Frame", { Size = UDim2.new(1, 0, 0.45, 0), BackgroundColor3 = theme.white, BackgroundTransparency = 0.62, BorderSizePixel = 0, ZIndex = 14, Parent = knob })
    corner(knobGloss, 4)

    local ref = { Row = row, Min = min, Max = max, Value = value, Fill = fill, FillShadow = fillShadow, Knob = knob, KnobShadow = knobShadow, ValueLabel = valueLabel, Title = title, Desc = desc, Format = format, Callback = callback, KnobYOffset = -4, KnobShadowYOffset = -6 }
    local function getSliderVisuals(alpha)
        local trackWidth = math.max(track.AbsoluteSize.X, track.Size.X.Offset, 1)
        local trackHeight = math.max(track.AbsoluteSize.Y, track.Size.Y.Offset, 1)
        local knobWidth = math.max(knob.AbsoluteSize.X, knob.Size.X.Offset, 1)
        local knobX = math.floor((alpha * (trackWidth - knobWidth)) + 0.5)
        local fillWidth
        if alpha <= 0 then
            fillWidth = 0
        elseif alpha >= 1 then
            fillWidth = trackWidth
        else
            fillWidth = math.clamp(knobX + (knobWidth * 0.5), 0, trackWidth)
        end
        return knobX, math.floor(fillWidth + 0.5), trackHeight
    end
    function ref:Set(v, instant)
        self.Value = clamp(v, self.Min, self.Max)
        local alpha = (self.Value - self.Min) / math.max(self.Max - self.Min, 0.0001)
        local knobX, fillWidth, trackHeight = getSliderVisuals(alpha)
        self.ValueLabel.Text = self.Format and self.Format(self.Value) or tostring(math.floor(self.Value + 0.5))
        if instant then
            self.Fill.Size = UDim2.fromOffset(fillWidth, trackHeight)
            if self.FillShadow then
                self.FillShadow.Size = UDim2.fromOffset(fillWidth, math.max(trackHeight - 4, 0))
            end
            self.Knob.Position = UDim2.fromOffset(knobX, self.KnobYOffset)
            if self.KnobShadow then
                self.KnobShadow.Position = UDim2.fromOffset(knobX - 2, self.KnobShadowYOffset)
            end
        else
            tween(self.Fill, { Size = UDim2.fromOffset(fillWidth, trackHeight) }, 0.14, Enum.EasingStyle.Circular)
            if self.FillShadow then
                tween(self.FillShadow, { Size = UDim2.fromOffset(fillWidth, math.max(trackHeight - 4, 0)) }, 0.14, Enum.EasingStyle.Circular)
            end
            tween(self.Knob, { Position = UDim2.fromOffset(knobX, self.KnobYOffset) }, 0.14, Enum.EasingStyle.Circular)
            if self.KnobShadow then
                tween(self.KnobShadow, { Position = UDim2.fromOffset(knobX - 2, self.KnobShadowYOffset) }, 0.14, Enum.EasingStyle.Circular)
            end
        end
        if not instant and type(self.Callback) == "function" then
            self.Callback(self.Value)
        end
    end
    local held = false
    local function sync(input)
        local rel = clamp(input.Position.X - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
        ref:Set(ref.Min + (ref.Max - ref.Min) * (rel / math.max(track.AbsoluteSize.X, 1)))
    end
    create("TextButton", { Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "", ZIndex = 15, Parent = track }).MouseButton1Down:Connect(function(x, y)
        held = true
        sync({ Position = Vector2.new(x, y) })
    end)
    manageConnection(UserInputService.InputChanged:Connect(function(input)
        if held and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            sync(input)
        end
    end))
    manageConnection(UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            held = false
        end
    end))
    onAccent(function(c)
        fill.BackgroundColor3 = c
        fillShadow.BackgroundColor3 = c:Lerp(Color3.fromRGB(20, 16, 24), 0.56)
        fillGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, c:Lerp(theme.white, 0.24)),
            ColorSequenceKeypoint.new(1, c),
        })
        fillShadowGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, c:Lerp(theme.white, 0.4)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(10, 8, 12)),
        })
    end)
    track:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        if track.AbsoluteSize.X > 0 and track.AbsoluteSize.Y > 0 then
            ref:Set(ref.Value, true)
        end
    end)
    task.defer(function() ref:Set(value, true) end)
    return ref
end

