    local desc = create("TextLabel", { Position = UDim2.fromOffset(18, 34), Size = UDim2.new(1, -142, 0, 18), BackgroundTransparency = 1, Font = Enum.Font.GothamMedium, Text = descText, TextColor3 = theme.muted, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 8, Parent = row })
    local button = create("TextButton", {
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -18, 0, 10),
        Size = UDim2.fromOffset(104, 34),
        BackgroundColor3 = Color3.fromRGB(27, 24, 33),
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Text = keybindDisplay(keyCode, false),
        TextColor3 = theme.text,
        TextSize = 12,
        AutoButtonColor = false,
        ZIndex = 9,
        Parent = row,
    })
    corner(button, 12)
    local buttonStroke = stroke(button, Color3.fromRGB(79, 72, 92), 0.58, 1)
    local ref = {
        Row = row,
        Button = button,
        Title = title,
        Desc = desc,
        Keybind = keyCode,
        Mode = mode == "Hold" and "Hold" or "Press",
        Holding = false,
        IsListening = false,
        Value = false,
        Callback = callback,
    }
    function ref:SetKeybind(nextKey)
        self.IsListening = false
        self.Keybind = typeof(nextKey) == "EnumItem" and nextKey.EnumType == Enum.KeyCode and nextKey ~= Enum.KeyCode.Unknown and nextKey or nil
        clearDuplicateKeybind(self, self.Keybind)
        self.Button.Text = keybindDisplay(self.Keybind, false)
    end
    function ref:SetMode(nextMode)
        self.Mode = nextMode == "Hold" and "Hold" or "Press"
        self.Holding = false
        self.Value = false
    end
    function ref:Trigger(active)
        if self.Mode == "Hold" then
            self.Holding = active == true
            self.Value = self.Holding
            tween(button, { BackgroundColor3 = self.Holding and Color3.fromRGB(38, 33, 46) or Color3.fromRGB(27, 24, 33) }, 0.12, Enum.EasingStyle.Quad)
            tween(buttonStroke, { Transparency = self.Holding and 0.18 or 0.58, Color = self.Holding and Color3.fromRGB(126, 117, 144) or Color3.fromRGB(79, 72, 92) }, 0.12, Enum.EasingStyle.Quad)
            if type(self.Callback) == "function" then
                self.Callback(self.Holding, self.Keybind)
            end
            return
        end
        tween(button, { BackgroundColor3 = Color3.fromRGB(38, 33, 46) }, 0.08, Enum.EasingStyle.Quad)
        tween(buttonStroke, { Transparency = 0.18, Color = Color3.fromRGB(126, 117, 144) }, 0.08, Enum.EasingStyle.Quad)
        task.delay(0.12, function()
            if button and button.Parent and not self.Holding then
                tween(button, { BackgroundColor3 = Color3.fromRGB(27, 24, 33) }, 0.12, Enum.EasingStyle.Quad)
                tween(buttonStroke, { Transparency = 0.58, Color = Color3.fromRGB(79, 72, 92) }, 0.12, Enum.EasingStyle.Quad)
            end
        end)
        if type(self.Callback) == "function" then
            self.Callback(self.Keybind)
        end
    end
    button.MouseButton1Click:Connect(function()
        beginKeyCapture(ref)
    end)
    bindableKeys[#bindableKeys + 1] = ref
    return ref
end

local function makeMultiDropdown(parent, y, titleText, descText, width, options, selected, callback)
    local row = create("Frame", { Position = UDim2.fromOffset(0, y), Size = UDim2.new(1, 0, 0, 84), BackgroundTransparency = 1, ZIndex = 7, Parent = parent })
    local textWidth = math.max(126, CARD_WIDTH - width - 82)
    local title = create("TextLabel", { Position = UDim2.fromOffset(18, 10), Size = UDim2.fromOffset(textWidth, 22), BackgroundTransparency = 1, Font = Enum.Font.GothamSemibold, Text = titleText, TextColor3 = theme.text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 8, Parent = row })
    local desc = create("TextLabel", { Position = UDim2.fromOffset(18, 38), Size = UDim2.fromOffset(textWidth, 18), BackgroundTransparency = 1, Font = Enum.Font.GothamMedium, Text = descText, TextColor3 = theme.muted, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 8, Parent = row })
    local pill = create("TextButton", { AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, -18, 0, 10), Size = UDim2.fromOffset(width, 38), BackgroundColor3 = Color3.fromRGB(27, 24, 33), BorderSizePixel = 0, Text = "", ZIndex = 8, Parent = row })
    corner(pill, 12)
    local pillStroke = stroke(pill, Color3.fromRGB(79, 72, 92), 0.58, 1)
    grad(pill, 90, {
        ColorSequenceKeypoint.new(0, Color3.fromRGB(34, 30, 39)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(17, 15, 21)),
    })
    local pillText = create("TextLabel", { Position = UDim2.fromOffset(12, 0), Size = UDim2.new(1, -30, 1, 0), BackgroundTransparency = 1, Font = Enum.Font.GothamMedium, Text = "None", TextColor3 = theme.text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 9, Parent = pill })
    local arrowLabel = create("TextLabel", { AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -10, 0.5, 0), Size = UDim2.fromOffset(12, 12), BackgroundTransparency = 1, Font = Enum.Font.GothamBold, Text = "v", TextColor3 = theme.muted, TextSize = 12, ZIndex = 9, Parent = pill })
    local ref = { Row = row, Open = false, Title = title, Desc = desc, Text = pillText, Pill = pill, Arrow = arrowLabel, Stroke = pillStroke, Width = width, Options = options or {}, Selected = {} }
    dropdowns[#dropdowns + 1] = ref
    function ref:GetSelected()
        local result = {}
        for option, enabled in pairs(self.Selected) do
            if enabled then
                result[#result + 1] = option
            end
        end
        table.sort(result)
        return result
    end
    function ref:RefreshText()
        local values = self:GetSelected()
        if #values == 0 then
            self.Text.Text = "None"
        elseif #values <= 2 then
            self.Text.Text = table.concat(values, ", ")
        else
            self.Text.Text = tostring(#values) .. " selected"
        end
    end
    function ref:Set(values)
        self.Selected = {}
        for _, option in ipairs(values or {}) do
            self.Selected[tostring(option)] = true
        end
        self:RefreshText()
        if type(callback) == "function" then
            callback(self:GetSelected())
        end
    end
    local function renderOptions()
        for _, button in ipairs(dropdownPopupButtons) do
            button:Destroy()
        end
        dropdownPopupButtons = {}
        local popupHeight = #ref.Options * 34 + 8
        local x = clamp(ref.Pill.AbsolutePosition.X - main.AbsolutePosition.X, 16, main.AbsoluteSize.X - ref.Width - 16)
        local yPos = ref.Pill.AbsolutePosition.Y - main.AbsolutePosition.Y + ref.Pill.AbsoluteSize.Y + 8
        if yPos + popupHeight > main.AbsoluteSize.Y - 16 then
            yPos = ref.Pill.AbsolutePosition.Y - main.AbsolutePosition.Y - popupHeight - 8
        end
        showDropdownPopup(Vector2.new(x, clamp(yPos, 16, main.AbsoluteSize.Y - popupHeight - 16)), UDim2.fromOffset(ref.Width, popupHeight))
        for index, option in ipairs(ref.Options) do
            local optionText = tostring(option)
            local selectedValue = ref.Selected[optionText] == true
            local opt = create("TextButton", {
                Position = UDim2.fromOffset(4, 4 + (index - 1) * 34),
                Size = UDim2.new(1, -8, 0, 30),
                BackgroundColor3 = selectedValue and Color3.fromRGB(42, 37, 49) or Color3.fromRGB(27, 24, 33),
                BorderSizePixel = 0,
                Text = "",
                ZIndex = 41,
                Parent = dropdownPopup,
            })
            corner(opt, 9)
            local optStroke = stroke(opt, selectedValue and Color3.fromRGB(126, 117, 144) or Color3.fromRGB(79, 72, 92), selectedValue and 0.18 or 0.58, 1)
            local dot = create("Frame", {
                Position = UDim2.fromOffset(8, 9),
                Size = UDim2.fromOffset(12, 12),
                BackgroundColor3 = selectedValue and state.accent or Color3.fromRGB(66, 60, 74),
                BorderSizePixel = 0,
                ZIndex = 42,
                Parent = opt,
            })
            corner(dot, 6)
            local label = create("TextLabel", {
                Position = UDim2.fromOffset(28, 0),
                Size = UDim2.new(1, -36, 1, 0),
                BackgroundTransparency = 1,
                Font = Enum.Font.GothamMedium,
                Text = optionText,
                TextColor3 = theme.text,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextTruncate = Enum.TextTruncate.AtEnd,
                ZIndex = 42,
                Parent = opt,
            })
            opt.MouseButton1Click:Connect(function()
                ref.Selected[optionText] = not ref.Selected[optionText]
                ref:RefreshText()
                if type(callback) == "function" then
                    callback(ref:GetSelected())
                end
                renderOptions()
            end)
            opt.MouseEnter:Connect(function()
                tween(opt, { BackgroundColor3 = selectedValue and Color3.fromRGB(50, 44, 58) or Color3.fromRGB(34, 30, 39) }, 0.12, Enum.EasingStyle.Quad)
                tween(optStroke, { Transparency = selectedValue and 0.12 or 0.42 }, 0.12, Enum.EasingStyle.Quad)
                tween(dot, { BackgroundColor3 = ref.Selected[optionText] and state.accent:Lerp(theme.white, 0.1) or Color3.fromRGB(88, 80, 100) }, 0.12, Enum.EasingStyle.Quad)
            end)
            opt.MouseLeave:Connect(function()
                tween(opt, { BackgroundColor3 = ref.Selected[optionText] and Color3.fromRGB(42, 37, 49) or Color3.fromRGB(27, 24, 33) }, 0.12, Enum.EasingStyle.Quad)
                tween(optStroke, { Transparency = ref.Selected[optionText] and 0.18 or 0.58 }, 0.12, Enum.EasingStyle.Quad)
                tween(dot, { BackgroundColor3 = ref.Selected[optionText] and state.accent or Color3.fromRGB(66, 60, 74) }, 0.12, Enum.EasingStyle.Quad)
            end)
            dropdownPopupButtons[#dropdownPopupButtons + 1] = opt
        end
    end
    pill.MouseButton1Click:Connect(function()
        if ref.Open then
            ref.Open = false
            tween(ref.Arrow, { Rotation = 0 }, 0.14, Enum.EasingStyle.Quart)
            tween(ref.Stroke, { Color = Color3.fromRGB(79, 72, 92), Transparency = 0.58 }, 0.14, Enum.EasingStyle.Quart)
            hideDropdownPopup()
            return
        end
        closeDropdowns()
        ref.Open = true
        tween(ref.Arrow, { Rotation = 180 }, 0.14, Enum.EasingStyle.Quart)
        tween(ref.Stroke, { Color = Color3.fromRGB(126, 117, 144), Transparency = 0.18 }, 0.14, Enum.EasingStyle.Quart)
        renderOptions()
    end)
    ref:Set(selected or {})
    return ref
end

