local function switchTab(name, x, w)
    if state.tab == name then
        return
    end
    closeDropdowns()
    closeToggleMenu(true)
    if setPickerOpen then
        setPickerOpen(false)
    end
    local previousTab = state.tab
    local previousX = tabRefs[previousTab] and tabRefs[previousTab].X or x
    local direction = x >= previousX and 1 or -1
    state.tab = name
    tabTransitionToken = tabTransitionToken + 1
    local token = tabTransitionToken
    contentFade.Visible = true
    contentFade.BackgroundTransparency = 1
    tween(contentFade, { BackgroundTransparency = 0.72 }, 0.12, Enum.EasingStyle.Sine)
    tween(content, { Position = UDim2.fromOffset(CONTENT_X - 6 * direction, CONTENT_Y) }, 0.12, Enum.EasingStyle.Sine)
    task.delay(0.11, function()
        if token ~= tabTransitionToken then
            return
        end
        if controls.ApplyProfile then
            controls.ApplyProfile(name)
        end
        content.Position = UDim2.fromOffset(CONTENT_X + 8 * direction, CONTENT_Y)
        tween(contentFade, { BackgroundTransparency = 1 }, 0.22, Enum.EasingStyle.Sine)
        tween(content, { Position = UDim2.fromOffset(CONTENT_X, CONTENT_Y) }, 0.28, Enum.EasingStyle.Circular)
        for _, ref in pairs(tabRefs) do
            ref.Sync(false)
        end
        tween(activeTabPill, {
            Position = UDim2.fromOffset(x, 5),
            Size = UDim2.fromOffset(w, 50),
            BackgroundColor3 = theme.panelSoft,
        }, 0.32, Enum.EasingStyle.Circular)
        task.delay(0.24, function()
            if token == tabTransitionToken and contentFade then
                contentFade.Visible = false
            end
        end)
    end)
end

local function makeSideButton(name, iconType, y)
    local frame = create("Frame", { Position = UDim2.fromOffset(11, y), Size = UDim2.fromOffset(72, 62), BackgroundColor3 = theme.shell2, BorderSizePixel = 0, ZIndex = 7, Parent = side })
    corner(frame, 18)
    local icon = makeAssetIcon(frame, ICON_SPRITES[iconType] or ICON_SPRITES.main, UDim2.fromOffset(23, 8), 26, 8)
    local hoverGlow = create("Frame", { Position = UDim2.fromOffset(2, 2), Size = UDim2.new(1, -4, 1, -4), BackgroundColor3 = theme.panel2, BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 7, Parent = frame })
    corner(hoverGlow, 16)
    local cornerAccents = makeCornerAccents(frame, 9)
    local label = create("TextLabel", {
        Position = UDim2.fromOffset(0, 38),
        Size = UDim2.fromOffset(72, 16),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = name,
        TextColor3 = SIDE_LABEL_MUTED,
        TextSize = 10,
        TextTransparency = 0.04,
        ZIndex = 8,
        Parent = frame,
    })
    local button = create("TextButton", { Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "", AutoButtonColor = false, ZIndex = 9, Parent = frame })
    local hovered = false
    local function syncVisuals(instant)
        local on = state.section == name
        local bg = on and theme.panel or theme.shell2
        local glowTransparency = on and 1 or (hovered and 0.28 or 1)
        local labelColor = on and theme.text or (hovered and theme.white or SIDE_LABEL_MUTED)
        local labelTransparency = on and 0 or (hovered and 0 or 0.04)
        local iconColor = on and theme.text or (hovered and theme.white or theme.muted)
        local accentColor = on and state.accent:Lerp(theme.white, 0.2) or (hovered and Color3.fromRGB(166, 157, 181) or Color3.fromRGB(132, 122, 145))
        local accentTransparency = on and 0 or (hovered and 0.14 or 1)
        if instant then
            frame.BackgroundColor3 = bg
            hoverGlow.BackgroundTransparency = glowTransparency
            label.TextColor3 = labelColor
            label.TextTransparency = labelTransparency
            setIconColor(icon, iconColor)
            for _, accent in ipairs(cornerAccents) do
                accent.BackgroundColor3 = accentColor
                accent.BackgroundTransparency = accentTransparency
            end
        else
            tween(frame, { BackgroundColor3 = bg }, 0.16)
            tween(hoverGlow, { BackgroundTransparency = glowTransparency }, 0.16)
            tween(label, { TextColor3 = labelColor, TextTransparency = labelTransparency }, 0.16)
            setIconColor(icon, iconColor)
            for _, accent in ipairs(cornerAccents) do
                tween(accent, { BackgroundColor3 = accentColor, BackgroundTransparency = accentTransparency }, 0.16)
            end
        end
    end
    button.MouseEnter:Connect(function()
        hovered = true
        syncVisuals(false)
    end)
    button.MouseLeave:Connect(function()
        hovered = false
        syncVisuals(false)
    end)
    button.MouseButton1Click:Connect(function()
        closeDropdowns()
        closeToggleMenu(true)
        state.section = name
        for key, ref in pairs(sideRefs) do
            local on = key == name
            ref.Sync(false)
            if on then tween(sideMark, { Position = UDim2.fromOffset(88, ref.Y + 11), BackgroundColor3 = state.accent }, 0.16) end
        end
    end)
    sideRefs[name] = { Frame = frame, Icon = icon, Label = label, Glow = hoverGlow, Y = y, Sync = syncVisuals }
    syncVisuals(true)
end

