local function normalizeSearchQuery(text)
    return string.lower(tostring(text or "")):gsub("^%s+", ""):gsub("%s+$", "")
end

local function getRefSearchText(ref)
    local parts = {}
    if ref.Title and ref.Title.Text then
        parts[#parts + 1] = ref.Title.Text
    end
    if ref.Desc and ref.Desc.Text then
        parts[#parts + 1] = ref.Desc.Text
    end
    if ref.Text and ref.Text.Text then
        parts[#parts + 1] = ref.Text.Text
    end
    if ref.ValueLabel and ref.ValueLabel.Text then
        parts[#parts + 1] = ref.ValueLabel.Text
    end
    if ref.Meta and ref.Meta.Text then
        parts[#parts + 1] = ref.Meta.Text
    end
    if ref.Hex and ref.Hex.Text then
        parts[#parts + 1] = ref.Hex.Text
    end
    return string.lower(table.concat(parts, " "))
end

local function updateGroupDividerVisibility(group)
    for index, dividerRef in ipairs(group.Dividers or {}) do
        local previousControl = group.Controls[index]
        local nextControl = group.Controls[index + 1]
        dividerRef.Visible = group.Card.Visible
            and previousControl and previousControl.Row and previousControl.Row.Visible
            and nextControl and nextControl.Row and nextControl.Row.Visible
    end
end

applySearchFilter = function(rawQuery)
    local query = normalizeSearchQuery(rawQuery)
    if query ~= "" then
        for tabName, tabRef in pairs(tabRefs) do
            if string.lower(tabName):find(query, 1, true) and state.tab ~= tabName then
                switchTab(tabName, tabRef.X, tabRef.W)
                break
            end
        end
    end
    for _, group in ipairs(searchGroups) do
        local groupVisible = query == ""
        local groupHeaderText = string.lower(group.Label.Text or "")
        if query ~= "" and groupHeaderText:find(query, 1, true) then
            groupVisible = true
        end
        local visibleCount = 0
        for _, ref in ipairs(group.Controls) do
            local matched = query == "" or getRefSearchText(ref):find(query, 1, true) ~= nil
            if ref.Row then
                ref.Row.Visible = matched
            end
            if matched then
                visibleCount = visibleCount + 1
            end
        end
        groupVisible = groupVisible or visibleCount > 0
        group.Card.Visible = groupVisible
        group.Label.Visible = groupVisible
        updateGroupDividerVisibility(group)
    end
    content.CanvasPosition = Vector2.new(0, 0)
end

