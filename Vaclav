    end
end

function WindowMethods:SetVisible(state)
    state = not not state
    if self.Visible == state then
        return
    end
    if not self.Main or not self.Overlay or not self.Gui then
        self.Visible = state
        return
    end

    self.Visible = state
    self._visibilitySequence = (self._visibilitySequence or 0) + 1
    local sequenceId = self._visibilitySequence
    local restingPosition = copyUDim2(self._visiblePosition or self.Main.Position)

    cancelVisibilityTweens(self)

    if state then
        local revealStartPosition = offsetUDim2(restingPosition, 0, windowToggleOffset)
        if not self.Gui.Enabled then
            self.Gui.Enabled = true
            self.Overlay.Visible = true
            self.Main.Visible = true
            self.Main.Position = revealStartPosition
            self.Overlay.BackgroundTransparency = 1
        else
            self.Overlay.Visible = true
            self.Main.Visible = true
        end
        self.Main.Visible = true
        self._visibilityTweens = {
            tween(self.Main, windowRevealTween, {Position = restingPosition}),
            tween(self.Overlay, windowRevealTween, {BackgroundTransparency = 0.62})
        }
    else
        self._visiblePosition = restingPosition
        local currentPosition = copyUDim2(self.Main.Position)
        local hiddenPosition = offsetUDim2(currentPosition, 0, windowToggleOffset)
        self._visibilityTweens = {
            tween(self.Main, windowHideTween, {Position = hiddenPosition}),
            tween(self.Overlay, windowHideTween, {BackgroundTransparency = 1})
        }
        task.delay(windowHideDuration, function()
            if self._destroyed or self._visibilitySequence ~= sequenceId then
                return
            end
            cancelVisibilityTweens(self)
            if not self.Visible and self.Main and self.Overlay and self.Gui then
                self.Main.Position = offsetUDim2(self._visiblePosition or currentPosition, 0, windowToggleOffset)
                self.Main.Visible = false
                self.Overlay.Visible = false
                self.Gui.Enabled = false
            end
        end)
    end
end

function WindowMethods:Toggle()
    self:SetVisible(not self.Visible)
end

function WindowMethods:Destroy()
    self._destroyed = true
    cancelVisibilityTweens(self)
    for _, connection in ipairs(self._connections) do
        if connection and connection.Disconnect then
            connection:Disconnect()
        end
    end
    self._connections = {}
    if self.Gui then
        self.Gui:Destroy()
    end
end

