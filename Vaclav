        Parent = body,
        FillDirection = Enum.FillDirection.Vertical,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6)
    })

    local collapseTween = TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local activeBodyTween

    local function getBodyHeight()
        return bodyLayout.AbsoluteContentSize.Y + bodyPaddingTop + bodyPaddingBottom
    end

    local function setCollapsed(state, immediate)
        panel.Collapsed = state == true
        local targetHeight = panel.Collapsed and 0 or getBodyHeight()
        if activeBodyTween then
            activeBodyTween:Cancel()
            activeBodyTween = nil
        end
        if immediate then
            bodyClip.Size = UDim2.new(1, 0, 0, targetHeight)
        else
            activeBodyTween = tween(bodyClip, collapseTween, {
                Size = UDim2.new(1, 0, 0, targetHeight)
            })
        end
        tween(chevron, fastTween, {Rotation = panel.Collapsed and 0 or 90})
        tween(chevronUpper, fastTween, {
            BackgroundColor3 = panel.Collapsed and tab.Window.Theme.SubText or tab.Window.Theme.Text
