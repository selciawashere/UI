function WindowMethods:SelectSection(section, preserveCurrentTab)
    if not section then
        return
    end

    for _, listed in ipairs(self.Sections) do
        local active = listed == section
        listed.Active = active
        if listed.Content then
            listed.Content.Visible = active
        end
        if listed.TabList then
            listed.TabList.Visible = active
        end
        if listed.ButtonShell then
            tween(listed.ButtonShell, fastTween, {
                BackgroundColor3 = self.Theme.Control,
                BackgroundTransparency = 1
            })
        end
        if listed.ButtonLabel then
            tween(listed.ButtonLabel, fastTween, {
                TextColor3 = active and self.Theme.Text or self.Theme.SubText
            })
        end
        tweenIconColor(listed.ButtonIcon, active and self.Theme.Text or self.Theme.SubText)
    end

    self.SelectedSection = section
    updateSectionBlob(self, section, true)

    if preserveCurrentTab == true then
        return
    end

    local targetTab = section.SelectedTab or section.Tabs[1]
    if targetTab then
        self:SelectTab(targetTab, true)
    else
        self.SelectedTab = nil
        updateTabBlob(self, nil, false)
    end
end

function WindowMethods:SelectTab(tab, sectionAlreadySelected)
    if not tab then
        return
    end
    if not sectionAlreadySelected and tab.Section and self.SelectedSection ~= tab.Section then
        self:SelectSection(tab.Section, true)
    end

    local previousTab = self.SelectedTab
    local isInitial = previousTab == nil
    local isSameTab = previousTab == tab

    local doAnimate = not isInitial and not isSameTab
        and previousTab ~= nil
        and previousTab.Section == tab.Section

    local direction = 1
    if doAnimate then
        local sectionTabs = (tab.Section and tab.Section.Tabs) or {}
        local prevIndex, newIndex = 0, 0
        for i, t in ipairs(sectionTabs) do
            if t == previousTab then prevIndex = i end
            if t == tab then newIndex = i end
        end
        if newIndex < prevIndex then
            direction = -1
        end
    end

    local switchTween = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

    for _, listed in ipairs(self.Tabs) do
        local ownerActive = listed.Section == self.SelectedSection
        local active = ownerActive and listed == tab
        listed.Active = active

        if listed.Page then
            if listed.PageScale then
                listed.PageScale.Scale = 1
            end
            if active then
                listed.Page.Visible = true
                if doAnimate then
                    listed.Page.Position = UDim2.new(direction, 0, 0, 0)
                    tween(listed.Page, switchTween, {Position = UDim2.new(0, 0, 0, 0)})
                else
                    listed.Page.Position = UDim2.new(0, 0, 0, 0)
                end
            elseif doAnimate and listed == previousTab then
                listed.Page.Visible = true
                tween(listed.Page, switchTween, {Position = UDim2.new(-direction, 0, 0, 0)})
                local capturedPage = listed.Page
                local capturedListed = listed
                task.delay(0.26, function()
                    if not capturedListed.Active and capturedPage then
                        capturedPage.Visible = false
                        capturedPage.Position = UDim2.new(0, 0, 0, 0)
                    end
                end)
            else
                listed.Page.Visible = false
                listed.Page.Position = UDim2.new(0, 0, 0, 0)
            end
        end

        if listed.ButtonFrame then
            tween(listed.ButtonFrame, fastTween, {
                BackgroundColor3 = self.Theme.Control,
                BackgroundTransparency = 1
            })
        end
        if listed.ButtonLabel then
            tween(listed.ButtonLabel, fastTween, {
                TextColor3 = active and self.Theme.Text or self.Theme.SubText
            })
        end
        tweenIconColor(listed.ButtonIcon, active and self.Theme.Text or self.Theme.SubText)
    end

    self.SelectedTab = tab
    if tab.Section then
        tab.Section.SelectedTab = tab
    end
    updateTabBlob(self, tab, doAnimate)
end

