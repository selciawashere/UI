    local function hold(duration)
        task.wait(math.max(duration * 0.98, 0.01))
    end

    local blurEffect
    if useBlur then
        local existingBlur = Lighting:FindFirstChild("IsaevaLoadBlur") or Lighting:FindFirstChild("VaclavLoadBlur")
        if existingBlur and existingBlur:IsA("BlurEffect") then
            pcall(function()
                existingBlur:Destroy()
            end)
        end
        blurEffect = Instance.new("BlurEffect")
        blurEffect.Size = 0
        blurEffect.Enabled = true
        blurEffect.Name = "IsaevaLoadBlur"
        local ok = pcall(function()
            blurEffect.Parent = Lighting
        end)
        if not ok then
            blurEffect = nil
        end
    end

    local logoRestPosition = UDim2.new(0.5, -splitTravel, 0.5, 0)
    local titleRestPosition = UDim2.new(0.5, splitTravel, 0.5, 0)

    tween(logo, ease(0.52), {ImageTransparency = 0})
    if blurEffect then
        tween(blurEffect, ease(0.58), {Size = 18})
    end
    hold(0.6)
    hold(0.72)

    tween(logo, ease(0.62), {
        Position = logoRestPosition
    })
    tween(titleLabel, ease(0.62), {
        Position = titleRestPosition,
        TextTransparency = 1
    })
    hold(0.36)
    tween(titleLabel, ease(0.42), {
        TextTransparency = 0
    })
    hold(0.72)

    if blurEffect then
        tween(blurEffect, ease(0.42), {Size = 0})
    end
    tween(logo, ease(0.42), {
        ImageTransparency = 1,
        Position = logoRestPosition
    })
    tween(titleLabel, ease(0.42), {
        TextTransparency = 1,
        Position = titleRestPosition
    })
    hold(0.44)

    if blurEffect then
        pcall(function()
            blurEffect:Destroy()
        end)
    end
    if loadRoot and loadRoot.Parent then
        loadRoot:Destroy()
    end
end

local function normalizeOptionList(values)
    local optionList = {}
    local seen = {}
    if type(values) == "table" then
        for _, value in ipairs(values) do
            local text = tostring(value)
            if not seen[text] then
                seen[text] = true
                table.insert(optionList, text)
            end
        end
    end
    return optionList
end

local function resolveSliderPrecision(explicitDecimals, minimum, maximum, increment, value)
    local decimals = tonumber(explicitDecimals)
    if decimals ~= nil then
        decimals = math.floor(decimals + 0.5)
    else
        decimals = math.max(
            countDecimals(minimum),
            countDecimals(maximum),
            countDecimals(increment),
            countDecimals(value)
        )
    end
    return clamp(decimals, 0, 6)
end

local function createValueText(value, suffix, decimals)
    if decimals and decimals > 0 then
        return string.format("%." .. tostring(decimals) .. "f%s", value, suffix or "")
    end
    return string.format("%d%s", roundToDecimals(value, 0), suffix or "")
end

local function normalizeAssetId(iconValue)
    if type(iconValue) ~= "string" then
        return nil
    end
    iconValue = iconValue:gsub("^%s+", ""):gsub("%s+$", "")
    if iconValue == "" then
        return nil
    end
    if string.find(iconValue, "rbxassetid://", 1, true) then
        return iconValue
    end
    if iconValue:match("^%d+$") then
        return "rbxassetid://" .. iconValue
    end
    return nil
end

local function resolveDefaultNavIcon(name)
    local key = string.lower(tostring(name or ""))
    if key == "main" then
        return "138297492544797"
    end
    if key == "settings" then
        return "123103299887543"
    end
    if key == "visuals" then
