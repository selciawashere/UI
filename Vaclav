end

local function createIconObject(parent, iconValue, color, size, position, anchorPoint, zIndex)
    local assetId = normalizeAssetId(iconValue)
    local commonProps = {
        Parent = parent,
        AnchorPoint = anchorPoint or Vector2.new(0, 0.5),
        Position = position or UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.new(0, size or 14, 0, size or 14),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = zIndex
    }

    if assetId then
        local iconCrop = 2
        local iconHolder = create("Frame", {
            Parent = commonProps.Parent,
            AnchorPoint = commonProps.AnchorPoint,
            Position = commonProps.Position,
            Size = commonProps.Size,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = commonProps.ZIndex
        })
        local iconImage = create("ImageLabel", {
            Name = "IconImage",
            Parent = iconHolder,
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(1, iconCrop * 2, 1, iconCrop * 2),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScaleType = Enum.ScaleType.Fit,
            Image = assetId,
            ImageColor3 = color,
            ZIndex = commonProps.ZIndex
        })
        preloadContent(iconImage, true)
        return iconHolder
    end

    if type(iconValue) == "string" and iconValue ~= "" then
        commonProps.Name = "IconLabel"
        commonProps.Font = Enum.Font.GothamBold
        commonProps.Text = iconValue
        commonProps.TextColor3 = color
        commonProps.TextSize = math.max((size or 14) - 2, 10)
        return create("TextLabel", commonProps)
    end

    return nil
end

local function tweenIconColor(iconObject, color)
    if not iconObject then
        return
    end
    if iconObject:IsA("Frame") then
        local nestedIcon = iconObject:FindFirstChild("IconImage") or iconObject:FindFirstChild("IconLabel")
        if nestedIcon then
            tweenIconColor(nestedIcon, color)
        end
        return
    end
    if iconObject:IsA("ImageLabel") or iconObject:IsA("ImageButton") then
        tween(iconObject, fastTween, {ImageColor3 = color})
    elseif iconObject:IsA("TextLabel") or iconObject:IsA("TextButton") then
        tween(iconObject, fastTween, {TextColor3 = color})
    end
end

local function measureTextWidth(text, textSize, font, padding, minimum, maximum)
    local bounds = TextService:GetTextSize(
        tostring(text or ""),
        tonumber(textSize) or 12,
        font or Enum.Font.GothamBold,
        Vector2.new(1000, 24)
    )
    local width = bounds.X + (tonumber(padding) or 0)
    if minimum then
        width = math.max(width, minimum)
    end
    if maximum then
        width = math.min(width, maximum)
    end
    return width
end

local function copyUDim2(value)
    return UDim2.new(
        value.X.Scale,
        value.X.Offset,
        value.Y.Scale,
        value.Y.Offset
    )
end

local function offsetUDim2(value, xOffset, yOffset)
    return UDim2.new(
        value.X.Scale,
        value.X.Offset + (tonumber(xOffset) or 0),
        value.Y.Scale,
        value.Y.Offset + (tonumber(yOffset) or 0)
    )
end

local function cancelVisibilityTweens(window)
    if not window or not window._visibilityTweens then
        return
