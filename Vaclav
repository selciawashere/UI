local function cancelTabBlobTweens(window)
    if not window or not window._tabBlobTweens then
        return
    end
    for _, activeTween in ipairs(window._tabBlobTweens) do
        if activeTween and activeTween.Cancel then
            activeTween:Cancel()
        end
    end
    window._tabBlobTweens = nil
end

local function getTabBlobGoal(window, tab)
    if not window or not window.TopTabHost or not tab or not tab.ButtonFrame then
        return nil, nil
    end

    local host = window.TopTabHost
    local button = tab.ButtonFrame
    local hostPosition = host.AbsolutePosition
    local buttonPosition = button.AbsolutePosition
    local buttonSize = button.AbsoluteSize

    return UDim2.new(
        0,
        buttonPosition.X - hostPosition.X,
        0,
        buttonPosition.Y - hostPosition.Y
    ), UDim2.new(0, buttonSize.X, 0, buttonSize.Y)
end

local function updateTabBlob(window, tab, animate)
    if not window or not window.TopTabBlob then
        return
    end

    local blob = window.TopTabBlob
    if not tab then
        cancelTabBlobTweens(window)
        blob.Visible = false
        return
    end

    local targetPosition, targetSize = getTabBlobGoal(window, tab)
    if not targetPosition or not targetSize then
        return
    end

    local hadBlob = blob.Visible and blob.Size.X.Offset > 0 and blob.Size.Y.Offset > 0
    window._tabBlobSequence = (window._tabBlobSequence or 0) + 1
    local sequenceId = window._tabBlobSequence

    cancelTabBlobTweens(window)
    blob.Visible = true

    if not animate or not hadBlob then
        blob.Position = targetPosition
        blob.Size = targetSize
        return
    end

    local startPosition = copyUDim2(blob.Position)
    local startSize = copyUDim2(blob.Size)
    local startLeft = startPosition.X.Offset
    local startRight = startLeft + startSize.X.Offset
    local targetLeft = targetPosition.X.Offset
    local targetRight = targetLeft + targetSize.X.Offset

    local stretchPosition
    local stretchSize
    if targetLeft >= startLeft then
        stretchPosition = UDim2.new(0, startLeft, 0, targetPosition.Y.Offset)
        stretchSize = UDim2.new(0, math.max(targetRight - startLeft, targetSize.X.Offset), 0, targetSize.Y.Offset)
    else
        stretchPosition = UDim2.new(0, targetLeft, 0, targetPosition.Y.Offset)
        stretchSize = UDim2.new(0, math.max(startRight - targetLeft, startSize.X.Offset), 0, targetSize.Y.Offset)
    end

    window._tabBlobTweens = {
        tween(blob, TweenInfo.new(0.14, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Position = stretchPosition,
            Size = stretchSize
        })
    }

    task.delay(0.09, function()
        if window._destroyed or window._tabBlobSequence ~= sequenceId or not blob.Parent then
            return
        end

        cancelTabBlobTweens(window)
        window._tabBlobTweens = {
            tween(blob, TweenInfo.new(0.18, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
                Position = targetPosition,
                Size = targetSize
            })
        }
    end)
end

