        Parent = rainbowButton,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -50, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = tostring(options.RainbowText or "Rainbow"),
        TextColor3 = window.Theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local rainbowTrack = create("Frame", {
        Parent = rainbowButton,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -10, 0.5, 0),
        Size = UDim2.new(0, trackWidth, 0, trackHeight),
        BackgroundColor3 = toggleTrackColor,
        BorderSizePixel = 0
    })
    applyCorner(rainbowTrack, 4)
    local rainbowKnob = create("Frame", {
        Parent = rainbowTrack,
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, knobInset, 0.5, 0),
        Size = UDim2.new(0, knobSize, 0, knobSize),
        BackgroundColor3 = toggleKnobOffColor,
        BorderSizePixel = 0
    })
    applyCorner(rainbowKnob, 3)

    local rowButton = create("TextButton", {
        Parent = row,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false
    })

    local function bindPanelButtonVisuals(button)
        connect(window, button.MouseEnter, function()
            tween(button, fastTween, {BackgroundColor3 = hoverBackground})
        end)
        connect(window, button.MouseLeave, function()
            tween(button, fastTween, {BackgroundColor3 = buttonBackground})
        end)
        connect(window, button.MouseButton1Down, function()
            tween(button, fastTween, {BackgroundColor3 = pressedBackground})
        end)
        connect(window, button.MouseButton1Up, function()
            tween(button, fastTween, {BackgroundColor3 = hoverBackground})
        end)
    end

    bindPanelButtonVisuals(confirmButton)

    local function refreshSummary(color)
        preview.BackgroundColor3 = color
        hexLabel.Text = toHex(color)
        rgbLabel.Text = toRgbText(color)
    end

    local function refreshRainbowVisual()
        tween(rainbowTrack, fastTween, {
            BackgroundColor3 = toggleTrackColor
        })
        tween(rainbowKnob, fastTween, {
            BackgroundColor3 = rainbowEnabled and toggleKnobOnColor or toggleKnobOffColor,
            Position = rainbowEnabled and UDim2.new(1, -(knobSize + knobInset), 0.5, 0) or UDim2.new(0, knobInset, 0.5, 0)
        })
    end

    local function emit()
        current = Color3.fromHSV(hue, saturation, value)
        refreshSummary(current)
        safeCall(options.Callback, current)
    end

    local function refreshVisual()
        local displayColor = Color3.fromHSV(hue, saturation, value)
        colorSurface.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        colorSelection.Position = UDim2.new(saturation, 0, 1 - value, 0)
        hueSelection.Position = UDim2.new(0.5, 0, hue, 0)
        refreshSummary(displayColor)
    end

    local function setOpen(state)
        open = state == true
        row.BackgroundColor3 = window.Theme.Control
        local target = open and 152 or 0
        if open then
            panel.Visible = true
        end
        tween(panel, midTween, {Size = UDim2.new(1, 0, 0, target)})
        if not open then
            task.delay(0.34, function()
                if not open and panel.Parent then
                    panel.Visible = false
                end
            end)
        end
    end

    local function stopRainbow()
        if not rainbowEnabled then
            return
        end
        rainbowEnabled = false
        rainbowToken = rainbowToken + 1
        refreshRainbowVisual()
    end

    local function startRainbow()
        stopRainbow()
        rainbowEnabled = true
        rainbowToken = rainbowToken + 1
        local token = rainbowToken
        saturation = 1
        value = 1
        refreshRainbowVisual()
        task.spawn(function()
            while rainbowEnabled and token == rainbowToken and not window._destroyed and wrapper.Parent do
                hue = (os.clock() * 0.15) % 1
                refreshVisual()
                emit()
                task.wait()
            end
        end)
    end

    local function setFromSatVal(mousePosition)
        local relativeX = clamp((mousePosition.X - colorSurface.AbsolutePosition.X) / colorSurface.AbsoluteSize.X, 0, 1)
        local relativeY = clamp((mousePosition.Y - colorSurface.AbsolutePosition.Y) / colorSurface.AbsoluteSize.Y, 0, 1)
        saturation = relativeX
        value = 1 - relativeY
        refreshVisual()
        emit()
    end

    local function setFromHue(mousePosition)
        local relative = clamp((mousePosition.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
        hue = relative
        if saturation <= grayscaleThreshold then
            saturation = 1
        end
        if value <= grayscaleThreshold then
            value = 1
        end
        refreshVisual()
        emit()
    end

    local function beginSatDrag(position)
        stopRainbow()
        satDragging = true
        setFromSatVal(position)
    end

    local function beginHueDrag(position)
        stopRainbow()
        hueDragging = true
        setFromHue(position)
    end

    connect(window, rowButton.MouseButton1Click, function()
        setOpen(not open)
    end)

    connect(window, colorSurface.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            beginSatDrag(input.Position)
        end
    end)
    connect(window, colorSelection.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            beginSatDrag(input.Position)
        end
    end)
    connect(window, hueBar.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            beginHueDrag(input.Position)
        end
    end)
    connect(window, hueSelection.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            beginHueDrag(input.Position)
        end
    end)
    connect(window, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            satDragging = false
            hueDragging = false
        end
    end)
    connect(window, UserInputService.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if satDragging then
                setFromSatVal(input.Position)
            elseif hueDragging then
                setFromHue(input.Position)
            end
        end
    end)
    connect(window, confirmButton.MouseButton1Click, function()
        setOpen(false)
    end)
    connect(window, rainbowButton.MouseButton1Click, function()
        if rainbowEnabled then
            stopRainbow()
            refreshVisual()
            emit()
        else
            startRainbow()
        end
    end)

    local object = {}
    function object:Set(color, silent)
        if typeof(color) ~= "Color3" then
            return
        end
        stopRainbow()
        hue, saturation, value = Color3.toHSV(color)
        refreshVisual()
        current = color
        if not silent then
            safeCall(options.Callback, current)
        end
    end
    function object:Get()
        return current
    end

    refreshVisual()
    refreshRainbowVisual()
    setOpen(false)
    if rainbowEnabled then
        startRainbow()
    else
        safeCall(options.Callback, current)
    end
    return object
end

