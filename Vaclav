    arrowIcon.AnchorPoint = Vector2.new(1, 0.5)
    arrowIcon.Position = UDim2.new(1, -12, 0, closedHeight / 2)
    arrowIcon.Size = UDim2.new(0, 11, 0, 11)
    arrowIcon.Rotation = 0

    local itemHolder = create("ScrollingFrame", {
        Parent = dropdown,
        Active = true,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 10, 0, 44),
        Size = UDim2.new(1, -20, 0, 0),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 0,
        ScrollBarImageColor3 = self.Window.Theme.ControlHover,
        ScrollBarImageTransparency = 1
    })
    local itemLayout = create("UIListLayout", {
        Parent = itemHolder,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, itemSpacing)
    })

    local optionButtons = {}

    local function selectedList()
        local result = {}
        for _, value in ipairs(optionList) do
            if selectedMap[value] then
                table.insert(result, value)
            end
        end
        return result
    end

    local function updateValueText()
        local list = selectedList()
        local suffix
        if #list == 0 then
            suffix = nil
        elseif #list == 1 then
            suffix = list[1]
        elseif #list == 2 then
            suffix = list[1] .. ", " .. list[2]
        else
            suffix = tostring(#list) .. " selected"
        end
        headerLabel.Text = suffix and (baseText .. " - " .. suffix) or baseText
    end

    local function visibleItemHeight()
        local count = math.min(#optionList, maxVisibleItems)
        if count <= 0 then
            return 0
        end
        return count * (itemHeight + itemSpacing)
    end

    local function targetDropdownHeight()
        if not open then
            return closedHeight
        end
        return 55 + visibleItemHeight()
    end

    local function refreshButtons()
        for _, optionValue in ipairs(optionList) do
            local button = optionButtons[optionValue]
            if button then
                tween(button, fastTween, {
                    BackgroundColor3 = backgroundColor
                })
            end
        end
        updateValueText()
    end

    local function refreshDropdownShell()
        local arrowColor = open and self.Window.Theme.Text or self.Window.Theme.SubText
        tween(dropdown, fastTween, {
            BackgroundColor3 = backgroundColor
        })
        tween(arrowUpper, fastTween, {
            BackgroundColor3 = arrowColor
        })
        tween(arrowLower, fastTween, {
            BackgroundColor3 = arrowColor
        })
    end

    local function setOpen(state)
        open = state == true
        tween(dropdown, expandTween, {
            Size = UDim2.new(1, 0, 0, targetDropdownHeight())
        })
        tween(arrowIcon, arrowTween, {
            Rotation = open and 90 or 0
        })
        refreshButtons()
        refreshDropdownShell()
    end

    local function toggleOption(optionValue, silent)
        selectedMap[optionValue] = not selectedMap[optionValue]
        refreshButtons()
        if not silent then
            safeCall(options.Callback, selectedList())
        end
    end

    local function rebuildOptions()
        for _, child in ipairs(itemHolder:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        optionButtons = {}
        itemHolder.Size = UDim2.new(1, -20, 0, visibleItemHeight())
        for _, optionValue in ipairs(optionList) do
            local item = create("TextButton", {
                Parent = itemHolder,
                Size = UDim2.new(1, 0, 0, itemHeight),
                BackgroundColor3 = backgroundColor,
                BorderSizePixel = 0,
                Text = optionValue,
                AutoButtonColor = false,
                Font = Enum.Font.GothamBold,
                TextColor3 = self.Window.Theme.Text,
                TextSize = 12
            })
            applyCorner(item, 3)
            optionButtons[optionValue] = item

            connect(self.Window, item.MouseEnter, function()
                tween(item, fastTween, {BackgroundColor3 = itemHoverColor})
            end)
            connect(self.Window, item.MouseLeave, function()
                tween(item, fastTween, {BackgroundColor3 = backgroundColor})
            end)
            connect(self.Window, item.MouseButton1Click, function()
                toggleOption(optionValue, false)
            end)
        end
        local valid = {}
        for _, optionValue in ipairs(optionList) do
            if selectedMap[optionValue] then
                valid[optionValue] = true
            end
        end
        selectedMap = valid
        refreshButtons()
        if not open then
            dropdown.Size = UDim2.new(1, 0, 0, closedHeight)
        else
            dropdown.Size = UDim2.new(1, 0, 0, targetDropdownHeight())
        end
    end

    connect(self.Window, dropdownButton.MouseButton1Click, function()
        setOpen(not open)
    end)

    local object = {}
    function object:Set(values, silent)
        selectedMap = {}
        if type(values) == "table" then
            for _, value in ipairs(values) do
                value = tostring(value)
                if table.find(optionList, value) then
                    selectedMap[value] = true
                end
            end
        end
        refreshButtons()
        if not silent then
            safeCall(options.Callback, selectedList())
        end
    end
    function object:Get()
        return selectedList()
    end
    function object:SetOptions(values, keepSelected)
        optionList = {}
        if type(values) == "table" then
            for _, value in ipairs(values) do
                table.insert(optionList, tostring(value))
            end
        end
        if not keepSelected then
            selectedMap = {}
        end
        rebuildOptions()
    end

    rebuildOptions()
    setOpen(false)
    safeCall(options.Callback, selectedList())
    return object
end


