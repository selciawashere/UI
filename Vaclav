            return
        end
        setSelected(value, silent)
    end
    function object:Get()
        return selected
    end
    function object:SetOptions(values, keepCurrent)
        optionList = {}
        if type(values) == "table" then
            for _, value in ipairs(values) do
                table.insert(optionList, tostring(value))
            end
        end
        if not keepCurrent then
            selected = optionList[1]
        end
        rebuildOptions()
