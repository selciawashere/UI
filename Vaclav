    else
        stretchPosition = UDim2.new(0, targetPosition.X.Offset, 0, targetTop)
        stretchSize = UDim2.new(0, targetSize.X.Offset, 0, math.max(startBottom - targetTop, startSize.Y.Offset))
    end

    window._sectionBlobTweens = {
