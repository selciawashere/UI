            BackgroundTransparency = 0.88
        })
        tweenIconColor(headerIcon, panel.Collapsed and tab.Window.Theme.SubText or tab.Window.Theme.Text)
    end

    connect(tab.Window, bodyLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
        if not panel.Collapsed then
            bodyClip.Size = UDim2.new(1, 0, 0, getBodyHeight())
        end
    end)

    connect(tab.Window, header.MouseButton1Click, function()
        setCollapsed(not panel.Collapsed)
    end)

    setCollapsed(panel.Collapsed, true)

    panel.Frame = frame
    panel.TitleLabel = title
    panel.GroupsHolder = body
    panel.ElementsHolder = body
    panel.Groups = {}

    table.insert(tab.Sections, panel)
    return panel
