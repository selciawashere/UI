local function updateSectionBlob(window, section, animate)
    if not window or not window.SectionBlob then
        return
    end

    local blob = window.SectionBlob
    if not section or not section.ButtonFrame or not section.ButtonFrame.Visible then
        cancelSectionBlobTweens(window)
