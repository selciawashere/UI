local function refreshSectionSearch(window)
    if not window or not window.Sections then
        return
    end

    local query = ""
    if window.SectionSearchBox then
        query = string.lower(window.SectionSearchBox.Text or "")
    end

    local firstVisible
    for _, section in ipairs(window.Sections) do
        local visible = query == "" or string.find(string.lower(section.Name), query, 1, true) ~= nil
        if section.ButtonFrame then
            section.ButtonFrame.Visible = visible
        end
        if visible and not firstVisible then
            firstVisible = section
        end
    end

    if window.SelectedSection and window.SelectedSection.ButtonFrame and not window.SelectedSection.ButtonFrame.Visible then
        if firstVisible then
            window:SelectSection(firstVisible)
        else
            updateSectionBlob(window, nil, false)
        end
    end
end

