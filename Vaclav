    local rainbowButton = create("TextButton", {
        Parent = panel,
        Position = UDim2.new(0, 10, 0, 122),
        Size = UDim2.new(0, 96, 0, 22),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Text = "",
        TextColor3 = window.Theme.Text,
        TextSize = 12,
        AutoButtonColor = false
    })
