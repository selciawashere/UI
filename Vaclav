local function preloadContent(target, immediate)
    if not target then
        return
    end

    local function runPreload()
        pcall(function()
            ContentProvider:PreloadAsync({target})
        end)
    end

    if immediate then
        runPreload()
    else
        task.spawn(runPreload)
    end
end

local function create(className, properties)
    local instance = Instance.new(className)
    local deferredParent = nil
    for key, value in pairs(properties) do
        if key == "Parent" then
            deferredParent = value
        else
            instance[key] = value
        end
    end
    if deferredParent ~= nil then
        instance.Parent = deferredParent
    end
    if (instance:IsA("ImageLabel") or instance:IsA("ImageButton")) and instance.Image ~= "" then
        preloadContent(instance, false)
    end
    return instance
end

local function connect(window, signal, callback)
    local connection = signal:Connect(callback)
    table.insert(window._connections, connection)
    return connection
end

local function tween(instance, tweenInfo, properties)
    local t = TweenService:Create(instance, tweenInfo, properties)
    t:Play()
    return t
end

local function setWindowDragBlock(instance)
    instance:SetAttribute("WindowDragBlock", true)
    return instance
end

local function hasWindowDragBlock(instance, root)
    local current = instance
    while current do
        if current:IsA("TextButton") or current:IsA("ImageButton") or current:IsA("TextBox") then
            return true
        end
        if current:GetAttribute("WindowDragBlock") == true then
            return true
        end
        if current == root then
            break
        end
        current = current.Parent
    end
    return false
end

local function shouldStartWindowDrag(window, position)
    if not window or not window.Main or not window.Main.Visible then
        return false
    end

    local mainPosition = window.Main.AbsolutePosition
    local mainSize = window.Main.AbsoluteSize
    if position.X < mainPosition.X or position.Y < mainPosition.Y then
        return false
    end
    if position.X > (mainPosition.X + mainSize.X) or position.Y > (mainPosition.Y + mainSize.Y) then
        return false
    end

    for _, guiObject in ipairs(window.Main:GetDescendants()) do
        if guiObject:IsA("GuiObject") and guiObject.Visible then
            local absolutePosition = guiObject.AbsolutePosition
            local absoluteSize = guiObject.AbsoluteSize
            if absoluteSize.X > 0 and absoluteSize.Y > 0 then
                local insideX = position.X >= absolutePosition.X and position.X <= (absolutePosition.X + absoluteSize.X)
                local insideY = position.Y >= absolutePosition.Y and position.Y <= (absolutePosition.Y + absoluteSize.Y)
                if insideX and insideY and hasWindowDragBlock(guiObject, window.Main) then
                    return false
                end
            end
        end
    end

    return true
end

local function safeCall(callback, ...)
    if typeof(callback) == "function" then
        task.spawn(callback, ...)
    end
end

local function clamp(value, minimum, maximum)
    if value < minimum then
        return minimum
    end
    if value > maximum then
        return maximum
    end
    return value
end

local function countDecimals(value)
    value = tonumber(value)
    if not value then
        return 0
    end
    local text = string.format("%.8f", math.abs(value))
    text = text:gsub("0+$", "")
    local dot = text:find("%.")
    if not dot then
        return 0
    end
    return #text - dot
end

local function roundToDecimals(value, decimals)
    decimals = math.max(0, math.floor(tonumber(decimals) or 0))
    local multiplier = 10 ^ decimals
    if value >= 0 then
        return math.floor(value * multiplier + 0.5) / multiplier
    end
    return math.ceil(value * multiplier - 0.5) / multiplier
end

local function roundToStep(value, step, minimum, decimals)
    if step <= 0 then
        if decimals and decimals > 0 then
            return roundToDecimals(value, decimals)
        end
        return value
    end
    local rounded = minimum + math.floor(((value - minimum) / step) + 0.5) * step
    local places = decimals
    if places == nil then
        places = math.max(countDecimals(step), countDecimals(minimum))
    end
    if places > 0 then
        rounded = roundToDecimals(rounded, places)
    end
    return rounded
end

local function lerpUDim2(a, b, alpha)
    return UDim2.new(
        a.X.Scale + (b.X.Scale - a.X.Scale) * alpha,
        a.X.Offset + (b.X.Offset - a.X.Offset) * alpha,
        a.Y.Scale + (b.Y.Scale - a.Y.Scale) * alpha,
        a.Y.Offset + (b.Y.Offset - a.Y.Offset) * alpha
    )
end

