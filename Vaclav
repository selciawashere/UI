function GroupMethods:AddLabel(options)
    options = options or {}
    local window = self.Window
    local text = tostring(options.Text or options.Name or "Label")
    local updateCallback = options.Update
    local autoUpdate = options.AutoUpdate
    local autoInterval
    if autoUpdate == true then
        autoInterval = tonumber(options.UpdateInterval) or 0.5
    elseif type(autoUpdate) == "number" then
        autoInterval = autoUpdate
    elseif options.UpdateInterval ~= nil then
        autoInterval = tonumber(options.UpdateInterval)
    end
    if autoInterval and autoInterval <= 0 then
        autoInterval = 0.1
    end
    local autoSilent = options.AutoUpdateSilent
    if autoSilent == nil then
        autoSilent = true
    end
    local autoToken = 0

    local card = createCard(self.ElementsHolder, window.Theme, 30)
    local label = create("TextLabel", {
        Parent = card,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -20, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = text,
        TextColor3 = window.Theme.SubText,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd
    })

    local object = {}

    local function setText(nextText, silent)
        nextText = tostring(nextText or "")
        if text == nextText then
            return
        end
        text = nextText
        label.Text = text
        if not silent then
            safeCall(options.Callback, text)
        end
    end

    function object:Set(nextText, silent)
        setText(nextText, silent)
    end

    function object:Get()
        return text
    end

    function object:Refresh(silent)
        if typeof(updateCallback) ~= "function" then
            return false
        end
        local ok, nextText = pcall(updateCallback, text)
        if not ok then
            return false
        end
        setText(nextText, silent)
        return true
    end

    function object:StopAutoUpdate()
        autoToken = autoToken + 1
    end

    function object:StartAutoUpdate(interval, silent)
        if typeof(updateCallback) ~= "function" then
            return
        end
        interval = tonumber(interval) or autoInterval or 0.5
        if interval <= 0 then
            interval = 0.1
        end
        autoToken = autoToken + 1
        local token = autoToken
        task.spawn(function()
            while token == autoToken and not window._destroyed and card.Parent do
                task.wait(interval)
                if token ~= autoToken or window._destroyed or not card.Parent then
                    break
                end
                object:Refresh(silent)
            end
        end)
    end

    if typeof(updateCallback) == "function" then
        object:Refresh(true)
        if autoInterval then
            object:StartAutoUpdate(autoInterval, autoSilent)
        end
    end
    safeCall(options.Callback, text)
    return object
end

function GroupMethods:AddToggle(options)
    options = options or {}
    local state = options.Default == true
    local toggleTrackColor = Color3.fromRGB(46, 46, 46)
    local toggleKnobOffColor = Color3.fromRGB(255, 255, 255)
    local toggleKnobOnColor = Color3.fromRGB(114, 47, 56)
    local toggleTween = TweenInfo.new(0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    local card = createCard(self.ElementsHolder, self.Window.Theme, 34)
    local trackWidth = 36
    local trackHeight = 22
    local knobSize = 14
    local knobInset = 4

    create("TextLabel", {
        Parent = card,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 0),
        Size = UDim2.new(1, -64, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = tostring(options.Name or "Toggle"),
        TextColor3 = self.Window.Theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local track = create("Frame", {
        Parent = card,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -8, 0.5, 0),
        Size = UDim2.new(0, trackWidth, 0, trackHeight),
        BackgroundColor3 = toggleTrackColor,
        BorderSizePixel = 0
    })
    applyCorner(track, 4)

    local knob = create("Frame", {
        Parent = track,
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, knobInset, 0.5, 0),
        Size = UDim2.new(0, knobSize, 0, knobSize),
        BackgroundColor3 = toggleKnobOffColor,
        BorderSizePixel = 0
    })
    applyCorner(knob, 3)

    local toggleButton = create("TextButton", {
        Parent = card,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -8, 0.5, 0),
        Size = UDim2.new(0, 42, 0, 28),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        BorderSizePixel = 0,
        ZIndex = 5
    })
    toggleButton.Selectable = false

    local activeTrackTween
    local activeKnobTween

    local function render(immediate)
        local targetTrack = toggleTrackColor
        local targetKnobColor = state and toggleKnobOnColor or toggleKnobOffColor
        local targetPos = state and UDim2.new(1, -(knobSize + knobInset), 0.5, 0) or UDim2.new(0, knobInset, 0.5, 0)
        if activeTrackTween then
            activeTrackTween:Cancel()
            activeTrackTween = nil
        end
        if activeKnobTween then
            activeKnobTween:Cancel()
            activeKnobTween = nil
        end
        if immediate then
            track.BackgroundColor3 = targetTrack
            knob.BackgroundColor3 = targetKnobColor
            knob.Position = targetPos
        else
            activeTrackTween = tween(track, toggleTween, {BackgroundColor3 = targetTrack})
            activeKnobTween = tween(knob, toggleTween, {BackgroundColor3 = targetKnobColor, Position = targetPos})
        end
    end

    local object = {}
    function object:Set(value, silent)
        local nextValue = not not value
        if state == nextValue then
            return
        end
        state = nextValue
        render(false)
        if not silent then
            safeCall(options.Callback, state)
        end
    end
    function object:Get()
        return state
    end

    connect(self.Window, toggleButton.MouseButton1Down, function()
        object:Set(not state, false)
    end)

    render(true)
    safeCall(options.Callback, state)
    return object
end

function GroupMethods:AddSlider(options)
    options = options or {}
    local minimum = tonumber(options.Min) or 0
    local maximum = tonumber(options.Max) or 100
    if maximum < minimum then
        minimum, maximum = maximum, minimum
    end
    local increment = tonumber(options.Increment) or 1
    if increment <= 0 then
        increment = 1
    end
    local suffix = tostring(options.Suffix or "")
    local explicitDecimals = options.Decimals
    if explicitDecimals == nil then
        explicitDecimals = options.Precision
    end
    local value = tonumber(options.Default)
    if value == nil then
        value = minimum
    end
    local decimals = resolveSliderPrecision(explicitDecimals, minimum, maximum, increment, value)
    value = clamp(roundToStep(value, increment, minimum, decimals), minimum, maximum)
    local sliderOffBackground = Color3.fromRGB(46, 46, 46)
    local sliderOnBackground = Color3.fromRGB(114, 47, 56)
    local sliderKnobColor = Color3.fromRGB(255, 255, 255)
    local sliderTween = TweenInfo.new(0.16, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)

    local card = createCard(self.ElementsHolder, self.Window.Theme, 52)
    create("TextLabel", {
        Parent = card,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 5),
        Size = UDim2.new(1, -70, 0, 16),
        Font = Enum.Font.GothamBold,
        Text = tostring(options.Name or "Slider"),
        TextColor3 = self.Window.Theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    local valueLabel = create("TextLabel", {
        Parent = card,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -66, 0, 5),
        Size = UDim2.new(0, 56, 0, 16),
        Font = Enum.Font.GothamBold,
        Text = "",
        TextColor3 = self.Window.Theme.SubText,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right
    })

    local bar = setWindowDragBlock(create("Frame", {
        Parent = card,
        Position = UDim2.new(0, 10, 0, 31),
        Size = UDim2.new(1, -20, 0, 8),
        BackgroundColor3 = sliderOffBackground,
        BorderSizePixel = 0
    }))
    applyCorner(bar, 3)

    local fill = create("Frame", {
        Parent = bar,
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = sliderOnBackground,
        BorderSizePixel = 0
    })
    applyCorner(fill, 3)

    local knob = create("Frame", {
        Parent = bar,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.new(0, 8, 0, 12),
        BackgroundColor3 = sliderKnobColor,
        BorderSizePixel = 0
    })
    applyCorner(knob, 2)

    local dragging = false
    local activeFillTween
    local activeKnobTween

    local function updateVisual(animated)
        local alpha = 0
        if maximum ~= minimum then
            alpha = (value - minimum) / (maximum - minimum)
        end
        alpha = clamp(alpha, 0, 1)
        valueLabel.Text = createValueText(value, suffix, decimals)
        local targetFill = UDim2.new(alpha, 0, 1, 0)
        local targetKnob = UDim2.new(alpha, 0, 0.5, 0)
        if activeFillTween then
            activeFillTween:Cancel()
            activeFillTween = nil
        end
        if activeKnobTween then
            activeKnobTween:Cancel()
            activeKnobTween = nil
        end
        if animated then
            activeFillTween = tween(fill, sliderTween, {Size = targetFill})
            activeKnobTween = tween(knob, sliderTween, {Position = targetKnob})
        else
            fill.Size = targetFill
            knob.Position = targetKnob
        end
    end

    local object = {}
    function object:Set(nextValue, silent, animate)
        nextValue = tonumber(nextValue)
        if not nextValue then
            return
        end
        nextValue = clamp(roundToStep(nextValue, increment, minimum, decimals), minimum, maximum)
        if nextValue == value then
            return
        end
        value = nextValue
        if animate == nil then
            animate = not dragging
        end
        updateVisual(animate)
        if not silent then
            safeCall(options.Callback, value)
        end
    end
    function object:Get()
        return value
    end

    local function setFromInputX(x, animate)
        local barX = bar.AbsolutePosition.X
        local barW = bar.AbsoluteSize.X
        if barW <= 0 then
            return
        end
        local alpha = clamp((x - barX) / barW, 0, 1)
        local raw = minimum + (maximum - minimum) * alpha
        object:Set(raw, false, animate)
    end

    connect(self.Window, bar.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            setFromInputX(input.Position.X, true)
        end
    end)
    connect(self.Window, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    connect(self.Window, UserInputService.InputChanged, function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            setFromInputX(input.Position.X, false)
        end
    end)

    updateVisual(false)
    safeCall(options.Callback, value)
    return object
end

function GroupMethods:AddDropdown(options)
    options = options or {}
    local window = self.Window
    local optionList = normalizeOptionList(type(options.Options) == "table" and options.Options or nil)
    local updateProvider = options.Update
    if typeof(updateProvider) ~= "function" and type(options.Options) == "function" then
        updateProvider = options.Options
    end
    local selected = options.Default and tostring(options.Default) or optionList[1]
    local open = false
    local autoToken = 0
    local autoUpdate = options.AutoUpdate
    local autoInterval
    if autoUpdate == true then
        autoInterval = tonumber(options.UpdateInterval) or 1
    elseif type(autoUpdate) == "number" then
        autoInterval = autoUpdate
    elseif options.UpdateInterval ~= nil and autoUpdate ~= false then
        autoInterval = tonumber(options.UpdateInterval)
    end
    if autoInterval and autoInterval <= 0 then
        autoInterval = 0.2
    end
    local autoSilent = options.AutoUpdateSilent
    if autoSilent == nil then
        autoSilent = true
    end
    local keepCurrentOnUpdate = options.KeepCurrentOnUpdate
    if keepCurrentOnUpdate == nil then
        keepCurrentOnUpdate = true
    end
    local hasRefreshButton = typeof(updateProvider) == "function" and options.UpdateButton ~= false
    local itemHeight = 25
    local itemSpacing = 1
    local maxVisibleItems = 3
    local baseHeight = 42
    local backgroundColor = window.Theme.Control
    local itemHoverColor = Color3.new(
        clamp(backgroundColor.R + 0.055, 0, 1),
        clamp(backgroundColor.G + 0.055, 0, 1),
        clamp(backgroundColor.B + 0.055, 0, 1)
    )
    local expandTween = TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local arrowTween = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local baseText = tostring(options.Name or "Dropdown")

    local dropdown = setWindowDragBlock(create("Frame", {
        Parent = self.ElementsHolder,
        Size = UDim2.new(1, 0, 0, baseHeight),
        BackgroundColor3 = backgroundColor,
        BorderSizePixel = 0,
        ClipsDescendants = true
    }))
    applyCorner(dropdown, 3)

    local dropdownButton = create("TextButton", {
        Parent = dropdown,
        Size = UDim2.new(1, 0, 0, baseHeight),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false
    })

    local headerLabel = create("TextLabel", {
        Parent = dropdown,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 13, 0, 0),
        Size = UDim2.new(1, hasRefreshButton and -76 or -44, 0, baseHeight),
        Font = Enum.Font.GothamBold,
        Text = baseText,
        TextColor3 = window.Theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd
    })

    local arrowIcon, arrowUpper, arrowLower = createChevronIcon(dropdown, window.Theme.SubText)
    arrowIcon.AnchorPoint = Vector2.new(1, 0.5)
    arrowIcon.Position = UDim2.new(1, -12, 0, baseHeight / 2)
    arrowIcon.Size = UDim2.new(0, 11, 0, 11)
    arrowIcon.Rotation = 0

    local refreshButton
    if hasRefreshButton then
        refreshButton = create("TextButton", {
            Parent = dropdown,
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -38, 0, baseHeight / 2),
            Size = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Font = Enum.Font.GothamBold,
            Text = tostring(options.UpdateButtonText or "↻"),
            TextColor3 = window.Theme.SubText,
            TextSize = 12,
            AutoButtonColor = false
        })
    end

    local itemHolder = create("ScrollingFrame", {
        Parent = dropdown,
        Active = true,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 10, 0, 44),
        Size = UDim2.new(1, -20, 0, 0),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 0,
        ScrollBarImageColor3 = window.Theme.ControlHover,
        ScrollBarImageTransparency = 1
    })
    local itemLayout = create("UIListLayout", {
        Parent = itemHolder,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, itemSpacing)
    })

    local optionButtons = {}

    local function frameSize()
        local visibleCount = math.min(#optionList, maxVisibleItems)
        if visibleCount <= 0 then
            return 0
        end
        return visibleCount * (itemHeight + itemSpacing)
    end

    local function refreshHeader()
        headerLabel.Text = selected and (baseText .. " - " .. selected) or baseText
    end

    local function refreshOptions()
        for _, optionValue in ipairs(optionList) do
            local button = optionButtons[optionValue]
            if button then
                tween(button, fastTween, {
                    BackgroundColor3 = backgroundColor
                })
            end
        end
    end

    local function refreshDropdownShell()
        local arrowColor = open and window.Theme.Text or window.Theme.SubText
        tween(dropdown, fastTween, {
            BackgroundColor3 = backgroundColor
        })
        tween(arrowUpper, fastTween, {
            BackgroundColor3 = arrowColor
        })
        tween(arrowLower, fastTween, {
            BackgroundColor3 = arrowColor
        })
    end

    local function setOpen(state)
        open = state == true
        tween(dropdown, expandTween, {
            Size = UDim2.new(1, 0, 0, open and (55 + frameSize()) or baseHeight)
        })
        tween(arrowIcon, arrowTween, {
            Rotation = open and 90 or 0
        })
        refreshDropdownShell()
    end

    local function setSelected(value, silent)
        if value ~= nil then
            value = tostring(value)
        end
        if selected == value then
            return
        end
        selected = value
        refreshHeader()
        refreshOptions()
        if not silent then
            safeCall(options.Callback, selected)
        end
    end

    local rebuildOptions

    local function applyOptionList(values, keepCurrent, silent)
        local previous = selected
        optionList = normalizeOptionList(values)
        if keepCurrent then
            if selected and not table.find(optionList, selected) then
                selected = optionList[1]
            end
            if not selected then
                selected = optionList[1]
            end
        else
            selected = optionList[1]
        end
        rebuildOptions()
        if selected ~= previous and not silent then
            safeCall(options.Callback, selected)
        end
    end

    local object = {}

    rebuildOptions = function()
        for _, child in ipairs(itemHolder:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        optionButtons = {}
        itemHolder.Size = UDim2.new(1, -20, 0, frameSize())
        for _, optionValue in ipairs(optionList) do
            local item = create("TextButton", {
                Parent = itemHolder,
                Size = UDim2.new(1, 0, 0, itemHeight),
                BackgroundColor3 = backgroundColor,
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Font = Enum.Font.GothamBold,
                Text = optionValue,
                TextColor3 = window.Theme.Text,
                TextSize = 12
            })
            applyCorner(item, 3)
            optionButtons[optionValue] = item

            connect(window, item.MouseEnter, function()
                tween(item, fastTween, {BackgroundColor3 = itemHoverColor})
            end)
            connect(window, item.MouseLeave, function()
                tween(item, fastTween, {BackgroundColor3 = backgroundColor})
            end)
            connect(window, item.MouseButton1Click, function()
                setSelected(optionValue, false)
                setOpen(false)
            end)
        end
        refreshHeader()
        refreshOptions()
        dropdown.Size = UDim2.new(1, 0, 0, open and (55 + frameSize()) or baseHeight)
    end

    connect(window, dropdownButton.MouseButton1Click, function()
        setOpen(not open)
    end)
    if refreshButton then
        connect(window, refreshButton.MouseEnter, function()
            tween(refreshButton, fastTween, {TextColor3 = window.Theme.Text})
        end)
        connect(window, refreshButton.MouseLeave, function()
            tween(refreshButton, fastTween, {TextColor3 = window.Theme.SubText})
        end)
        connect(window, refreshButton.MouseButton1Click, function()
            object:Refresh(keepCurrentOnUpdate, false)
        end)
    end
    function object:Set(value, silent)
        if value ~= nil and not optionButtons[tostring(value)] then
            return
        end
        setSelected(value, silent)
    end
    function object:Get()
        return selected
    end
    function object:SetOptions(values, keepCurrent, silent)
        if silent == nil then
            silent = true
        end
        applyOptionList(values, keepCurrent == true, silent)
    end
    function object:Refresh(keepCurrent, silent)
        if typeof(updateProvider) ~= "function" then
            return false
        end
        if keepCurrent == nil then
            keepCurrent = true
        end
        if silent == nil then
            silent = false
        end
        local ok, values = pcall(updateProvider, selected, optionList)
        if not ok or type(values) ~= "table" then
            return false
        end
        applyOptionList(values, keepCurrent, silent)
        return true
    end
    function object:StopAutoUpdate()
        autoToken = autoToken + 1
    end
    function object:StartAutoUpdate(interval, keepCurrent, silent)
        if typeof(updateProvider) ~= "function" then
            return
        end
        interval = tonumber(interval) or autoInterval or 1
        if interval <= 0 then
            interval = 0.2
        end
        if keepCurrent == nil then
            keepCurrent = true
        end
        if silent == nil then
            silent = true
        end
        autoToken = autoToken + 1
        local token = autoToken
        task.spawn(function()
            while token == autoToken and not window._destroyed and wrapper.Parent do
                task.wait(interval)
                if token ~= autoToken or window._destroyed or not wrapper.Parent then
                    break
                end
                object:Refresh(keepCurrent, silent)
            end
        end)
    end

    rebuildOptions()
    setOpen(false)
    if typeof(updateProvider) == "function" then
        object:Refresh(keepCurrentOnUpdate, true)
        if autoInterval then
            object:StartAutoUpdate(autoInterval, keepCurrentOnUpdate, autoSilent)
        end
    end
    safeCall(options.Callback, selected)
    return object
end

