SectionMethods.AddKeybind = GroupMethods.AddKeybind
SectionMethods.AddColorPicker = GroupMethods.AddColorPicker

function Library:CreateWindow(options)
    options = options or {}
    local resolvedThemeInput = options.Theme ~= nil and options.Theme or "Vaclav"
    local initialThemeName = resolveThemeName(resolvedThemeInput)
    local theme = mergeTheme(resolvedThemeInput)
    local shouldPlayLoadAnimation = options.LoadAnimation
    if shouldPlayLoadAnimation == nil then
        shouldPlayLoadAnimation = true
    end
    local shouldUseLoadBlur = options.LoadBlur
    if shouldUseLoadBlur == nil then
        shouldUseLoadBlur = true
    end
    if typeof(options.AccentColor) == "Color3" then
        theme.Accent = options.AccentColor
        if typeof(options.AccentDark) == "Color3" then
            theme.AccentDark = options.AccentDark
        else
            theme.AccentDark = Color3.new(
                clamp(theme.Accent.R * 0.72, 0, 1),
                clamp(theme.Accent.G * 0.72, 0, 1),
                clamp(theme.Accent.B * 0.72, 0, 1)
            )
        end
        initialThemeName = "Custom"
    end

    local parent = resolveGuiParent()
    if not parent then
        error("Unable to resolve a GUI parent")
    end

    local gui = create("ScreenGui", {
        Name = tostring(options.Name or "GalaxyUI"),
        Enabled = false,
        IgnoreGuiInset = true,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = parent
    })

    local overlay = create("Frame", {
        Parent = gui,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = theme.Background,
        BackgroundTransparency = 0.62,
        BorderSizePixel = 0
    })

    local main = create("Frame", {
        Parent = gui,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = options.Size or UDim2.new(0, 640, 0, 480),
        BackgroundColor3 = theme.Window,
        BorderSizePixel = 0
    })
    applyCorner(main, 4)
    applyStroke(main, theme.Stroke, 0.72, 1)
    local mainScale = create("UIScale", {
        Parent = main,
        Scale = 1
    })

    local logoId = tostring(options.Logo or options.HeaderLogo or options.BrandLogo or "108702816998934")
    if not string.find(logoId, "rbxassetid://", 1, true) then
        logoId = "rbxassetid://" .. logoId
    end

    local logoCrop = clamp(math.floor(tonumber(options.LogoCrop) or 3), 0, 8)
    local topTitle = tostring(options.HeaderTitle or options.Name or options.BrandName or "Vaclav Hub")
    local brandName = tostring(options.BrandName or options.Name or topTitle)

    local sidebarWidth = 170
    local side = create("Frame", {
        Parent = main,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0, sidebarWidth, 1, 0),
        BackgroundColor3 = theme.Panel,
        BorderSizePixel = 0
    })
    applyCorner(side, 4)
    applyStroke(side, theme.Stroke, 0.84, 1)
    local sectionBlob = create("Frame", {
        Parent = side,
        Visible = false,
        BackgroundColor3 = theme.ControlHover,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 0, 0),
        ZIndex = 0
    })
    applyCorner(sectionBlob, 4)

    local brandPanel = create("Frame", {
        Parent = side,
        Size = UDim2.new(1, 0, 0, 48),
        BackgroundTransparency = 1,
        BorderSizePixel = 0
    })

    local brandLogoClip = create("Frame", {
        Parent = brandPanel,
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 14, 0.5, 0),
        Size = UDim2.new(0, 20, 0, 20),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ClipsDescendants = true
    })
    local brandLogo = create("ImageLabel", {
        Parent = brandLogoClip,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, logoCrop * 2, 1, logoCrop * 2),
        ScaleType = Enum.ScaleType.Fit,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Image = logoId
    })
    preloadContent(brandLogo, true)
    create("TextLabel", {
        Parent = brandPanel,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 40, 0, 0),
        Size = UDim2.new(1, -52, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = brandName,
        TextColor3 = theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local searchFrame = create("Frame", {
        Parent = side,
        Position = UDim2.new(0, 10, 0, 58),
        Size = UDim2.new(1, -20, 0, 34),
        BackgroundColor3 = theme.Control,
        BorderSizePixel = 0
    })
    applyCorner(searchFrame, 4)
    applyStroke(searchFrame, theme.Stroke, 0.88, 1)
    searchFrame.Visible = false

    local searchBox = create("TextBox", {
        Parent = searchFrame,
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ClearTextOnFocus = false,
        Font = Enum.Font.GothamBold,
        PlaceholderText = tostring(options.SearchPlaceholder or "Search"),
        PlaceholderColor3 = theme.SubText,
        Text = "",
        TextColor3 = theme.Text,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local sectionList = create("ScrollingFrame", {
        Parent = side,
        Position = UDim2.new(0, 10, 0, 58),
        Size = UDim2.new(1, -20, 1, -110),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 0,
        ScrollBarImageTransparency = 1,
        ScrollBarImageColor3 = theme.AccentDark
    })
    create("UIListLayout", {
        Parent = sectionList,
        FillDirection = Enum.FillDirection.Vertical,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6)
    })

    create("Frame", {
        Parent = side,
        Visible = false,
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, 10, 1, -50),
        Size = UDim2.new(1, -20, 0, 1),
        BackgroundColor3 = theme.Stroke,
        BackgroundTransparency = 0.84,
        BorderSizePixel = 0
    })
    local settingsBottomArea = create("Frame", {
        Parent = side,
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, 10, 1, -10),
        Size = UDim2.new(1, -20, 0, 34),
        BackgroundTransparency = 1,
        BorderSizePixel = 0
    })

    local content = create("Frame", {
        Parent = main,
        Position = UDim2.new(0, sidebarWidth + 10, 0, 10),
        Size = UDim2.new(1, -(sidebarWidth + 20), 1, -20),
        BackgroundTransparency = 1
    })

    local topBar = create("Frame", {
        Parent = content,
        Size = UDim2.new(1, 0, 0, 46),
        BackgroundColor3 = theme.Panel,
        BorderSizePixel = 0
    })
    applyCorner(topBar, 4)
    applyStroke(topBar, theme.Stroke, 0.86, 1)
    topBar.Visible = false

    local topTabHost = create("Frame", {
        Parent = topBar,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ClipsDescendants = true
    })
    local topTabBlob = create("Frame", {
        Parent = topTabHost,
        Visible = false,
        BackgroundColor3 = theme.ControlHover,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 0, 0),
        ZIndex = 0
    })
    applyCorner(topTabBlob, 3)
    applyStroke(topTabBlob, theme.Stroke, 0.88, 1)

    local keyHint = create("TextLabel", {
        Parent = topBar,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -14, 0.5, 0),
        Size = UDim2.new(0, 190, 0, 18),
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = "",
        TextColor3 = theme.SubText,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Right,
        Visible = false
    })

    local contentPages = create("Frame", {
        Parent = content,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true
    })

    local notifHolder = create("Frame", {
        Parent = gui,
        AnchorPoint = Vector2.new(1, 1),
        Position = UDim2.new(1, -18, 1, -18),
        Size = UDim2.new(0, 312, 0, 360),
        BackgroundTransparency = 1
    })
    create("UIListLayout", {
        Parent = notifHolder,
        FillDirection = Enum.FillDirection.Vertical,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 8),
        VerticalAlignment = Enum.VerticalAlignment.Bottom
    })

    local window = setmetatable({
        Gui = gui,
        Theme = theme,
        ThemeName = initialThemeName,
        Overlay = overlay,
        Main = main,
        MainScale = mainScale,
        Side = side,
        SectionBlob = sectionBlob,
        TopBar = topBar,
        TopTabHost = topTabHost,
        TopTabBlob = topTabBlob,
        SectionList = sectionList,
        SectionSearchBox = searchBox,
        ContentPages = contentPages,
        TabList = topTabHost,
        Pages = contentPages,
        NotificationHolder = notifHolder,
        KeyHint = keyHint,
        BrandName = brandName,
        BrandLogoId = logoId,
        Sections = {},
        Tabs = {},
        SelectedSection = nil,
        SelectedTab = nil,
        Visible = true,
        ToggleKey = isEnumKeyCode(options.ToggleKey) and options.ToggleKey or Enum.KeyCode.RightControl,
        _connections = {},
        _keybindEntries = {},
        _awaitingKeybind = nil,
        _toggleBindControl = nil,
        _themeDropdownControl = nil,
        _themeChangedCallback = options.ThemeChangedCallback,
        _navActiveBackground = theme.ControlHover,
        _navActiveText = theme.Text,
        _navInactiveText = theme.SubText,
        _visiblePosition = copyUDim2(main.Position),
        _visibilityTweens = nil,
        _visibilitySequence = 0,
        _sectionBlobTweens = nil,
        _sectionBlobSequence = 0,
        _tabBlobTweens = nil,
        _tabBlobSequence = 0,
        _rootSection = nil,
        _rootSectionName = tostring(options.RootSectionName or "Main"),
        _rootSectionIcon = options.RootSectionIcon or "138297492544797",
        _destroyed = false
    }, {__index = WindowMethods})

    keyHint.Text = "Toggle Key: " .. keyCodeToText(window.ToggleKey)

    if shouldPlayLoadAnimation then
        main.Visible = false
        overlay.Visible = false
        overlay.BackgroundTransparency = 1
        main.Position = offsetUDim2(window._visiblePosition, 0, windowToggleOffset)
    end

    local dragging = false
    local dragStart
    local startPos
    local function beginDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end

    connect(window, UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    connect(window, UserInputService.InputChanged, function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            local nextPosition = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            main.Position = nextPosition
            if window.Visible then
                window._visiblePosition = copyUDim2(nextPosition)
            end
        end
    end)
    connect(window, searchBox:GetPropertyChangedSignal("Text"), function()
        refreshSectionSearch(window)
    end)

    connect(window, UserInputService.InputBegan, function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if shouldStartWindowDrag(window, input.Position) then
                beginDrag(input)
            end
            return
        end
        if gameProcessed then
            return
        end
        if input.UserInputType ~= Enum.UserInputType.Keyboard then
            return
        end
        if window._awaitingKeybind then
            local resolver = window._awaitingKeybind
            window._awaitingKeybind = nil
            resolver(input.KeyCode)
            return
        end
        if input.KeyCode == window.ToggleKey then
            window:Toggle()
            return
        end
        if UserInputService:GetFocusedTextBox() then
            return
        end
        for _, bind in ipairs(window._keybindEntries) do
            if bind.Key == input.KeyCode and bind.Key ~= Enum.KeyCode.Unknown then
                safeCall(bind.Callback, input.KeyCode)
            end
        end
    end)

    window._settingsThemeControl = nil
    local builtInSettingsEnabled = options.DisableBuiltInSettings ~= true
    if builtInSettingsEnabled then
        local settingsCategory = window:CreateSection({
            Name = tostring(options.SettingsCategoryName or "Settings"),
            Icon = options.SettingsIcon or "123103299887543",
            AutoSelect = options.SelectBuiltInSettings == true
        })
        settingsCategory.ButtonFrame.Parent = settingsBottomArea
        settingsCategory.ButtonFrame.Size = UDim2.new(1, 0, 1, 0)
        local settingsTab = settingsCategory:AddTab({
            Name = tostring(options.SettingsTabName or "Window"),
            AutoSelect = options.SelectBuiltInSettings == true
        })
        local settingsSection = settingsTab:AddGroup({
            Name = tostring(options.SettingsSectionName or "Interface"),
            Side = "Left"
        })
        local toggleBind = settingsSection:AddKeybind({
            Name = tostring(options.ToggleBindName or "Toggle UI"),
            Default = window.ToggleKey,
            ChangedCallback = function(newKey)
                window:SetToggleKey(newKey, false)
                keyHint.Text = "Toggle Key: " .. keyCodeToText(window.ToggleKey)
            end
        })
        window._toggleBindControl = toggleBind
        settingsSection:AddButton({
            Name = tostring(options.HideNowButtonName or "Hide Interface"),
            Callback = function()
                window:SetVisible(false)
            end
        })
        settingsSection:AddButton({
            Name = tostring(options.DestroyButtonName or "Destroy Interface"),
            Callback = function()
                window:Destroy()
            end
        })

        local showThemeChooser = false
        if showThemeChooser then
            window._settingsThemeControl = settingsTab:ThemeCreate({
                SectionName = tostring(options.ThemeSectionName or "Themes"),
                Side = tostring(options.ThemeSide or "Right"),
                DropdownName = tostring(options.ThemeDropdownName or "Style"),
                ButtonName = tostring(options.ThemeButtonName or "Apply Style"),
                Default = window.ThemeName,
                InstantApply = options.InstantThemeApply == true,
                Callback = options.ThemeCallback
            })
        end
    end

    if shouldPlayLoadAnimation then
        gui.Enabled = true
        local ok, loadErr = pcall(playLoadAnimation, gui, theme, logoId, topTitle, shouldUseLoadBlur)
        if not ok then
            warn("[Isaeva Hub] Load animation failed:", loadErr)
            local staleBlur = Lighting:FindFirstChild("IsaevaLoadBlur") or Lighting:FindFirstChild("VaclavLoadBlur")
            if staleBlur and staleBlur:IsA("BlurEffect") then
                pcall(function()
                    staleBlur:Destroy()
                end)
            end
            local staleLoadRoot = gui:FindFirstChild("IsaevaLoadRoot")
            if staleLoadRoot then
                staleLoadRoot:Destroy()
            end
        end
        overlay.Visible = true
        main.Visible = true
        window._visibilityTweens = {
            tween(main, windowRevealTween, {Position = window._visiblePosition}),
            tween(overlay, windowRevealTween, {BackgroundTransparency = 0.62})
        }
    else
        gui.Enabled = true
    end

    if options.ShowLoadNotification ~= false then
        window:Notify({
            Title = "UI Loaded",
            Duration = 2
        })
    end

    return window
end

function Library.new(options)
    options = options or {}
    local mapped = {}
    for key, value in pairs(options) do
        mapped[key] = value
    end
    if mapped.Theme == nil then
        mapped.Theme = "Vaclav"
    end
    mapped.Name = mapped.Name or mapped.HeaderTitle or mapped.BrandName or "Vaclav Hub"
    mapped.HeaderTitle = mapped.HeaderTitle or mapped.Name
    mapped.BrandName = mapped.BrandName or mapped.Name
    if mapped.DisableBuiltInSettings == nil then
        mapped.DisableBuiltInSettings = true
    end
    return Library:CreateWindow(mapped)
end

return Library
