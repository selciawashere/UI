function WindowMethods:SetTheme(themeInput, silent, syncControl)
    local oldTheme = self.Theme
    local resolvedInput = themeInput
    if resolvedInput == nil then
        if self.ThemeName == "Custom" then
            resolvedInput = self.Theme
        else
            resolvedInput = self.ThemeName or "Vaclav"
        end
    end
    local newTheme = mergeTheme(resolvedInput)
    self.Theme = newTheme
    self.ThemeName = resolveThemeName(resolvedInput)
    self._navActiveBackground = newTheme.ControlHover
    self._navActiveText = newTheme.Text
    self._navInactiveText = newTheme.SubText
    applyThemeToHierarchy(self.Gui, oldTheme, newTheme)

    if self.SelectedSection then
        self:SelectSection(self.SelectedSection, true)
    end
    if self.SelectedTab then
        self:SelectTab(self.SelectedTab, true)
    end
    refreshSectionSearch(self)

    if syncControl ~= false and self._themeDropdownControl and self._themeDropdownControl.Get and self._themeDropdownControl.Set then
        local dropdownValue = self._themeDropdownControl:Get()
        local targetValue = self.ThemeName
        if dropdownValue ~= targetValue and (targetValue == "Custom" or table.find(self:GetThemeNames(), targetValue)) then
            self._themeDropdownControl:Set(targetValue, true)
        end
    end

    if not silent then
        safeCall(self._themeChangedCallback, self.ThemeName, copyTheme(self.Theme))
    end
    return self.Theme
end

function WindowMethods:ApplyTheme(themeInput, silent, syncControl)
